{
  "info": {
    "name": "Bareeq Manager Portal — MANAGER role",
    "description": "Read-only manager web endpoints (FRD §3).\n\nPrerequisites:\n• A MANAGER user exists. Use the Sprint 1 admin collection to create one if needed.\n• Set `managerEmail` and `managerPassword` in the environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{managerToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "00 — Auth",
      "item": [
        {
          "name": "POST /auth/web/login (MANAGER → managerToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.success) {",
                  "  pm.environment.set('managerToken', j.data.accessToken);",
                  "  pm.environment.set('managerId', j.data.user.id);",
                  "  console.log('✅ MANAGER logged in');",
                  "} else {",
                  "  console.log('❌ login failed:', JSON.stringify(j));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/web/login", "host": ["{{baseUrl}}"], "path": ["auth", "web", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{managerEmail}}\",\n  \"password\": \"{{managerPassword}}\"\n}"
            }
          }
        },
        {
          "name": "POST /auth/mobile/login (MANAGER — MUST FAIL 403, web-only)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/mobile/login", "host": ["{{baseUrl}}"], "path": ["auth", "mobile", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{managerEmail}}\",\n  \"password\": \"{{managerPassword}}\"\n}"
            },
            "description": "FRD §3 — Manager web app only. Mobile login must be rejected."
          }
        }
      ]
    },

    {
      "name": "01 — Profile (FRD §3.1)",
      "item": [
        {
          "name": "GET /manager/my-profile",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/my-profile",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "my-profile"]
            },
            "description": "Returns: id, role=MANAGER, name, email, phone."
          }
        },
        {
          "name": "GET /manager/my-profile (as ADMIN — MUST FAIL 403)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/my-profile",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "my-profile"]
            },
            "description": "Admins don't share the manager portal. Should return 403."
          }
        }
      ]
    },

    {
      "name": "02 — Teams List (FRD §3.2.1 / §3.2.2 / §3.2.3)",
      "item": [
        {
          "name": "GET /manager/teams (default — current month)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/teams",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "teams"]
            },
            "description": "One row per (supervisor × company) for the current month. Each row carries: supervisor info, companyName, cities[], regions[], totalBranches, and visit/documentation counters."
          }
        },
        {
          "name": "GET /manager/teams (specific month)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/teams?year=2026&month=8",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "teams"],
              "query": [
                { "key": "year", "value": "2026" },
                { "key": "month", "value": "8" }
              ]
            }
          }
        },
        {
          "name": "GET /manager/teams (search by supervisorName — FRD §3.2.2)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/teams?supervisorName=Ali",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "teams"],
              "query": [{ "key": "supervisorName", "value": "Ali" }]
            },
            "description": "Case-insensitive match against either nameAr or nameEn."
          }
        },
        {
          "name": "GET /manager/teams (filters — FRD §3.2.3)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/teams?companyName=Carrefour&city=Riyadh&region=Central",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "teams"],
              "query": [
                { "key": "companyName", "value": "Carrefour" },
                { "key": "city", "value": "Riyadh" },
                { "key": "region", "value": "Central" }
              ]
            },
            "description": "Filters compose — all are AND-ed together at the DB layer."
          }
        }
      ]
    },

    {
      "name": "03 — Implemented Branches (FRD §3.5)",
      "item": [
        {
          "name": "GET /manager/branches (default — current month)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.success && j.data?.items?.[0]) {",
                  "  pm.environment.set('managerBranchId', j.data.items[0].id);",
                  "  console.log('✅ stashed managerBranchId:', j.data.items[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/branches",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "branches"]
            },
            "description": "All scheduled branches across the platform for the current month. Same shape as /company/branches plus a `supervisor` field."
          }
        },
        {
          "name": "GET /manager/branches (filters + search — FRD §3.5.3/4)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/branches?companyName=Carrefour&city=Riyadh&visitType=2",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "branches"],
              "query": [
                { "key": "companyName", "value": "Carrefour" },
                { "key": "city", "value": "Riyadh" },
                { "key": "visitType", "value": "2" }
              ]
            }
          }
        },
        {
          "name": "GET /manager/branches/:id (FRD §3.5.6)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/branches/{{managerBranchId}}",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "branches", "{{managerBranchId}}"]
            },
            "description": "Full branch detail (same shape as /company/branches/:id) plus the supervisor block. Run the list first to populate {{managerBranchId}}."
          }
        },
        {
          "name": "GET /manager/branches/:bogus (MUST FAIL 404)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/branches/notarealid000000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "branches", "notarealid000000000000000"]
            },
            "description": "Unknown id → 404 'Branch not found'."
          }
        },
        {
          "name": "GET /manager/branches/export.xlsx (FRD §3.5.5)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/branches/export.xlsx",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "branches", "export.xlsx"]
            },
            "description": "Excel export honoring the same filters as the JSON list. Hard cap: 5000 rows."
          }
        },
        {
          "name": "GET /manager/branches/export.pdf",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/branches/export.pdf",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "branches", "export.pdf"]
            },
            "description": "Same data as the Excel export, printable A4 landscape."
          }
        }
      ]
    },

    {
      "name": "04 — Reports / Monthly by Company (FRD §3.6)",
      "item": [
        {
          "name": "GET /manager/reports/by-company (default — current month)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/reports/by-company",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "reports", "by-company"]
            },
            "description": "Per-company → per-branch breakdown with counters per V (total / implemented / remaining / documented / undocumented), plus company-level and grand totals."
          }
        },
        {
          "name": "GET /manager/reports/by-company (specific month)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/reports/by-company?year=2026&month=8",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "reports", "by-company"],
              "query": [
                { "key": "year", "value": "2026" },
                { "key": "month", "value": "8" }
              ]
            }
          }
        },
        {
          "name": "GET /manager/reports/by-company?companyName=Carrefour",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/reports/by-company?companyName=Carrefour",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "reports", "by-company"],
              "query": [{ "key": "companyName", "value": "Carrefour" }]
            },
            "description": "FRD §3.6.2 filter. Case-insensitive `contains` match."
          }
        },
        {
          "name": "GET /manager/reports/by-company/export.xlsx",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/reports/by-company/export.xlsx",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "reports", "by-company", "export.xlsx"]
            },
            "description": "Flat Excel: one row per (company × brand × V). Pivot-friendly."
          }
        },
        {
          "name": "GET /manager/reports/by-company/export.pdf",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/reports/by-company/export.pdf",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "reports", "by-company", "export.pdf"]
            },
            "description": "Same flat data as the xlsx; grand totals printed in the subtitle band."
          }
        }
      ]
    },


    {
      "name": "11 — Representatives (FRD §3.10)",
      "description": "Prerequisite: run 'npm run prisma:migrate' once so the representatives table exists. Price is computed server-side from hourlyRate × numberOfWorkers × numberOfHours — never trusted from the client.",
      "item": [
        {
          "name": "POST /manager/representatives (price auto-computed)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.success && j.data?.id) {",
                  "  pm.environment.set('representativeId', j.data.id);",
                  "  console.log('✅ rep id:', j.data.id, '— computed price:', j.data.price);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/manager/representatives",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "representatives"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientName\": \"Lulu Hypermarket\",\n  \"serviceType\": \"Mystery Shopper\",\n  \"hourlyRate\": 50,\n  \"numberOfWorkers\": 3,\n  \"numberOfHours\": 8,\n  \"dateOfAgreement\": \"2026-05-12\",\n  \"customerPhoneNumber\": \"+966500111222\"\n}"
            },
            "description": "FRD §3.10.2 — price MUST be computed server-side. Body above yields price = 50 × 3 × 8 = 1200 SAR."
          }
        },
        {
          "name": "POST /manager/representatives (try to spoof price — server ignores it)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/manager/representatives",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "representatives"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientName\": \"Test\",\n  \"serviceType\": \"X\",\n  \"hourlyRate\": 100,\n  \"numberOfWorkers\": 2,\n  \"numberOfHours\": 4,\n  \"dateOfAgreement\": \"2026-05-12\",\n  \"price\": 1\n}"
            },
            "description": "The body sends price=1, but the server recomputes from inputs: 100 × 2 × 4 = 800. This is the security boundary."
          }
        },
        {
          "name": "GET /manager/representatives (list)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/representatives",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "representatives"]
            }
          }
        },
        {
          "name": "GET /manager/representatives (search — FRD §3.10.3)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/representatives?clientName=Lulu&dateFrom=2026-05-01",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "representatives"],
              "query": [
                { "key": "clientName", "value": "Lulu" },
                { "key": "dateFrom", "value": "2026-05-01" }
              ]
            }
          }
        },
        {
          "name": "GET /manager/representatives/:id (FRD §3.10.6)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/representatives/{{representativeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "representatives", "{{representativeId}}"]
            }
          }
        },
        {
          "name": "PATCH /manager/representatives/:id (recomputes price)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/manager/representatives/{{representativeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "representatives", "{{representativeId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"numberOfWorkers\": 5\n}"
            },
            "description": "Changing any of (hourlyRate, numberOfWorkers, numberOfHours) recomputes price using the merged inputs. Other fields stay as-is — no need to resend everything."
          }
        },
        {
          "name": "DELETE /manager/representatives/:id",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/manager/representatives/{{representativeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "representatives", "{{representativeId}}"]
            }
          }
        },
        {

    {
      "name": "08 — Additional Tasks (FRD §3.9)",
      "description": "Prerequisite: run 'npm run prisma:migrate' once so the additional_tasks table exists. Also: set {{supervisorId}} in the environment to an existing supervisor before creating tasks.",
      "item": [
        {
          "name": "POST /manager/additional-tasks (create)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.success && j.data?.id) {",
                  "  pm.environment.set('additionalTaskId', j.data.id);",
                  "  console.log('✅ task id:', j.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/manager/additional-tasks",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "additional-tasks"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"supervisorId\": \"{{supervisorId}}\",\n  \"companyName\": \"Carrefour\",\n  \"branchName\": \"Carrefour\",\n  \"categoryName\": \"Hypermarket\",\n  \"address\": \"الرياض - حي الورود\",\n  \"location\": \"https://maps.google.com/?q=24.71,46.71\",\n  \"latitude\": 24.71,\n  \"longitude\": 46.71,\n  \"visitDate\": \"2026-05-20\",\n  \"price\": 500,\n  \"notes\": \"زيارة إضافية للمتابعة\"\n}"
            },
            "description": "FRD §3.9.2 — required fields: supervisorId, companyName, address, visitDate. Everything else optional."
          }
        },
        {
          "name": "GET /manager/additional-tasks (list)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/additional-tasks",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "additional-tasks"]
            },
            "description": "Paginated list. Each row carries manager + supervisor info, address, status, documentation status."
          }
        },
        {
          "name": "GET /manager/additional-tasks (search + filter)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/additional-tasks?companyName=Carrefour&status=REMAINING",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "additional-tasks"],
              "query": [
                { "key": "companyName", "value": "Carrefour" },
                { "key": "status", "value": "REMAINING" }
              ]
            },
            "description": "FRD §3.9.3 + §3.9.4. Supported: supervisorId/Name, companyName, branchName, brandName, address, status, documentationStatus, dateFrom, dateTo."
          }
        },
        {
          "name": "GET /manager/additional-tasks/:id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/additional-tasks/{{additionalTaskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "additional-tasks", "{{additionalTaskId}}"]
            }
          }
        },
        {
          "name": "PATCH /manager/additional-tasks/:id",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/manager/additional-tasks/{{additionalTaskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "additional-tasks", "{{additionalTaskId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 750,\n  \"notes\": \"تم تعديل السعر\"\n}"
            },

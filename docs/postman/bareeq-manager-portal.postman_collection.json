          }
        },
        {
          "name": "DELETE /manager/additional-tasks/:id",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/manager/additional-tasks/{{additionalTaskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "additional-tasks", "{{additionalTaskId}}"]
            },
            "description": "Soft delete — row stays in DB with deletedAt set."
          }
        },
        {
          "name": "GET /manager/additional-tasks/export.xlsx",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/additional-tasks/export.xlsx",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "additional-tasks", "export.xlsx"]
            }
          }
        },
        {
          "name": "GET /manager/additional-tasks/export.pdf",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/manager/additional-tasks/export.pdf",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "additional-tasks", "export.pdf"]
            }
          }
        }
      ]
    },

    {
      "name": "09 — Monthly Sales / Clients (FRD §3.7)",
      "description": "Prerequisite: run 'npm run prisma:migrate' once so the clients table exists.",
      "item": [
        {
          "name": "POST /manager/clients (create)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.success && j.data?.id) {",
                  "  pm.environment.set('clientId', j.data.id);",
                  "  console.log('✅ client id:', j.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/manager/clients",
              "host": ["{{baseUrl}}"],
              "path": ["manager", "clients"]
            },
            "body": {

            },
            "description": "Partial update. KYC document upload is NOT here — it lives in a separate /kyc/submit endpoint (Sprint 4) that handles file upload + sets kycStatus = PENDING."
          }
        },
        {
          "name": "POST /service-provider/profile/change-password",
          "request": {

              "raw": "{\n  \"currentPassword\": \"{{spPassword}}\",\n  \"newPassword\": \"newspXYZ456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "08 — Admin Customers (FRD §3.2.1)",
      "item": [
        {
          "name": "GET /admin/customers (list + filters)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/customers?page=1&limit=20&sort=newest",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "customers"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "q", "value": "", "disabled": true, "description": "search email/phone/name" },
                { "key": "status", "value": "ENABLED", "disabled": true, "description": "ENABLED | BLOCKED" },
                { "key": "sort", "value": "newest", "description": "newest | oldest | name" }
              ]
            }
          }
        },
        {
          "name": "GET /admin/customers/:id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/customers/{{customerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "customers", "{{customerId}}"]
            }
          }
        },
        {
          "name": "PATCH /admin/customers/:id/status (block/unblock)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/customers/{{customerId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "customers", "{{customerId}}", "status"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"BLOCKED\",\n  \"reason\": \"Suspicious activity (audit only)\"\n}"
            },
            "description": "Block (BLOCKED) revokes every active refresh token + bars login. Unblock (ENABLED) is idempotent — no token action. The `reason` is logged for audit; will surface in customer notifications when those ship in Sprint 4."
          }
        }
      ]
    },
    {
      "name": "09 — Admin Service Providers (FRD §3.2.2 + §2.1)",
      "item": [
        {
          "name": "GET /admin/service-providers (list + filters)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/service-providers?page=1&limit=20&sort=newest",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "service-providers"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "q", "value": "", "disabled": true },
                { "key": "status", "value": "ENABLED", "disabled": true },
                { "key": "kycStatus", "value": "PENDING", "disabled": true, "description": "NOT_SUBMITTED | PENDING | APPROVED | REJECTED" },
                { "key": "isVerified", "value": "true", "disabled": true },
                { "key": "sort", "value": "newest", "description": "newest | oldest | name | rating | pendingFirst" }
              ]
            },
            "description": "Use `sort=pendingFirst` to surface SPs awaiting KYC review at the top of the list."
          }
        },
        {
          "name": "GET /admin/service-providers/:id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/service-providers/{{spId}}",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "service-providers", "{{spId}}"]
            }
          }
        },
        {
          "name": "PATCH /admin/service-providers/:id/status (block/unblock)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/service-providers/{{spId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "service-providers", "{{spId}}", "status"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"BLOCKED\",\n  \"reason\": \"Multiple customer complaints (audit only)\"\n}"
            }
          }
        },
        {
          "name": "PATCH /admin/service-providers/:id/kyc (approve/reject)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/service-providers/{{spId}}/kyc",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "service-providers", "{{spId}}", "kyc"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"decision\": \"APPROVED\",\n  \"notes\": \"All docs valid\"\n}"
            },
            "description": "APPROVED → sets kycStatus=APPROVED + isVerified=true + verifiedAt=now. REJECTED → kycStatus=REJECTED + isVerified=false + verifiedAt=null (clears any prior approval). `notes` is audit-only for now; will go into the SP's KYC-result notification in Sprint 4."
          }
        }
      ]
    },
    {
      "name": "10 — Customer Bookings (FRD §1.3)",
      "item": [
        {
          "name": "POST /customer/bookings (create) — captures bookingId",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data) {",
                  "  pm.environment.set('bookingId', res.data.id);",
                  "  console.log('Booking created — total:', res.data.totalCost);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerAccessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/customer/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["customer", "bookings"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"serviceId\": \"{{serviceId}}\",\n  \"subcategoryIds\": [\n    \"{{subcategoryId1}}\",\n    \"{{subcategoryId2}}\"\n  ],\n  \"description\": \"حاجة عاجلة\",\n  \"locationAddress\": \"الرياض - الصحافة\",\n  \"locationLat\": 24.7136,\n  \"locationLng\": 46.6753,\n  \"scheduledDate\": \"2026-12-01T10:00:00.000Z\",\n  \"paymentMethod\": \"CASH\"\n}"
            },
            "description": "totalCost is computed server-side as the SUM of cost across the selected subcategories. All subcategoryIds must belong to the chosen service.\n\nMVP only supports `CASH`; WALLET / ONLINE are rejected with 400 until Sprint 4 payment integration."
          }
        },
        {
          "name": "GET /customer/bookings (list own + filter)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerAccessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/customer/bookings?page=1&limit=20&sort=newest",
              "host": ["{{baseUrl}}"],
              "path": ["customer", "bookings"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "status", "value": "PENDING", "disabled": true, "description": "PENDING | APPROVED | IN_PROGRESS | COMPLETED | CANCELLED | REJECTED" },
                { "key": "sort", "value": "newest" }
              ]
            }
          }
        },
        {
          "name": "GET /customer/bookings/:id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerAccessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/customer/bookings/{{bookingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["customer", "bookings", "{{bookingId}}"]
            }
          }
        },
        {
          "name": "POST /customer/bookings/:id/cancel",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerAccessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/customer/bookings/{{bookingId}}/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["customer", "bookings", "{{bookingId}}", "cancel"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"no longer needed\"\n}"
            },
            "description": "Allowed ONLY while status=PENDING. Once an SP has accepted (APPROVED), the customer must contact admin/SP — the dispute flow lands in Sprint 4."
          }
        }
      ]
    },
    {
      "name": "11 — Service Provider Bookings (FRD §2.2 + §2.3)",
      "item": [
        {
          "name": "GET /service-provider/bookings/pool (PENDING open pool)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{spAccessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/service-provider/bookings/pool?page=1&limit=20&sort=oldestFirst",
              "host": ["{{baseUrl}}"],
              "path": ["service-provider", "bookings", "pool"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "serviceId", "value": "", "disabled": true },
                { "key": "sort", "value": "oldestFirst" }
              ]
            },
            "description": "Requires the SP to be `isVerified=true` (admin-approved KYC). Returns 403 otherwise."
          }
        },
        {
          "name": "POST /service-provider/bookings/:id/accept",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{spAccessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/service-provider/bookings/{{bookingId}}/accept",
              "host": ["{{baseUrl}}"],
              "path": ["service-provider", "bookings", "{{bookingId}}", "accept"]
            },
            "description": "Atomic claim: only one SP wins per booking. Locks commissionRate + commissionAmount at this moment (admin can't retroactively change them). Returns 409 if booking is already taken or no longer PENDING."
          }
        },
        {
          "name": "GET /service-provider/bookings (my assigned)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{spAccessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/service-provider/bookings?page=1&limit=20&sort=newest",
              "host": ["{{baseUrl}}"],
              "path": ["service-provider", "bookings"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "status", "value": "APPROVED", "disabled": true },
                { "key": "sort", "value": "newest" }
              ]
            }
          }
        },
        {
          "name": "POST /service-provider/bookings/:id/start (APPROVED → IN_PROGRESS)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{spAccessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/service-provider/bookings/{{bookingId}}/start",
              "host": ["{{baseUrl}}"],
              "path": ["service-provider", "bookings", "{{bookingId}}", "start"]
            }
          }
        },
        {
          "name": "POST /service-provider/bookings/:id/complete (IN_PROGRESS → COMPLETED)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{spAccessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/service-provider/bookings/{{bookingId}}/complete",
              "host": ["{{baseUrl}}"],
              "path": ["service-provider", "bookings", "{{bookingId}}", "complete"]
            },
            "description": "For CASH bookings, completion also flips paymentStatus to PAID (paid in cash on delivery). WALLET / ONLINE flows mark PAID at charge time instead — Sprint 4."
          }
        }
      ]
    },

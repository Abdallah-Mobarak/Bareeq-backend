{
  "info": {
    "name": "Bareeq API — Sprint 1 Additions",
    "description": "Permissions, Region Scheduling, Accountant Managers, Assign Company, Admins, Manager Tasks. Import this alongside the main Bareeq API collection. Run requests top-to-bottom; each one stashes the ids the next ones need into environment vars.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "00 — Login (run first)",
      "item": [
        {
          "name": "POST /auth/web/login (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.success) {",
                  "  pm.environment.set('accessToken', j.data.accessToken);",
                  "  pm.environment.set('refreshToken', j.data.refreshToken);",
                  "  pm.environment.set('adminId', j.data.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/web/login", "host": ["{{baseUrl}}"], "path": ["auth", "web", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            }
          }
        }
      ]
    },

    {
      "name": "06 — Permissions Catalog",
      "item": [
        {
          "name": "GET /permissions (grouped by module)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/permissions",
              "host": ["{{baseUrl}}"],
              "path": ["permissions"]
            }
          }
        },
        {
          "name": "GET /permissions?grouped=false (flat)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/permissions?grouped=false",
              "host": ["{{baseUrl}}"],
              "path": ["permissions"],
              "query": [{ "key": "grouped", "value": "false" }]
            }
          }
        }
      ]
    },

    {
      "name": "07 — Permission Roles (CRUD)",
      "item": [
        {
          "name": "POST /permission-roles (create role)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.success) pm.environment.set('permissionRoleId', j.data.role.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/permission-roles",
              "host": ["{{baseUrl}}"],
              "path": ["permission-roles"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Reports Manager\",\n  \"permissionKeys\": [\n    \"VIEW_TEAMS\",\n    \"EXPORT_TEAMS\",\n    \"VIEW_MONTHLY_REPORTS\",\n    \"EXPORT_MONTHLY_REPORTS\",\n    \"VIEW_SALES\",\n    \"EXPORT_SALES\"\n  ]\n}"
            }
          }
        },
        {
          "name": "GET /permission-roles",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/permission-roles",
              "host": ["{{baseUrl}}"],
              "path": ["permission-roles"]
            }
          }
        },
        {
          "name": "GET /permission-roles/:id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/permission-roles/{{permissionRoleId}}",
              "host": ["{{baseUrl}}"],
              "path": ["permission-roles", "{{permissionRoleId}}"]
            }
          }
        },
        {
          "name": "PATCH /permission-roles/:id (replace permissions)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/permission-roles/{{permissionRoleId}}",
              "host": ["{{baseUrl}}"],
              "path": ["permission-roles", "{{permissionRoleId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Reports Manager (renamed)\",\n  \"permissionKeys\": [\"VIEW_TEAMS\", \"EXPORT_TEAMS\", \"VIEW_MONTHLY_REPORTS\"]\n}"
            }
          }
        },
        {
          "name": "DELETE /permission-roles/:id",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/permission-roles/{{permissionRoleId}}",
              "host": ["{{baseUrl}}"],
              "path": ["permission-roles", "{{permissionRoleId}}"]
            }
          }
        }
      ]
    },


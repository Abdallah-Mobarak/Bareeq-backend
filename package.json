{
  "name": "bareeq-backend",
  "version": "0.1.0",
  "description": "Bareeq platform backend — Management System + Services Marketplace",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset",
    "seed:admin": "node scripts/seed-admin.js",
    "seed:marketplace-admin": "node scripts/seed-marketplace-admin.js",
    "seed:permissions": "node scripts/seed-permissions.js",
    "seed:locations": "node scripts/seed-locations.js",
    "seed:categories": "node scripts/seed-categories.js",
    "seed:notifications": "node scripts/seed-notifications.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.js\" \"prisma/**/*.prisma\" \"*.{json,md,js}\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "test": "jest"
  },
  "keywords": [
    "bareeq",
    "field-visits",
    "services-marketplace"
  ],
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "archiver": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.8",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "prisma": "^6.19.3"
  }
}

// ============================================
// Prisma Schema — Bareeq Backend
// ============================================
// Docs: https://www.prisma.io/docs
// After any change here, run:  npm run prisma:migrate
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

/// The system-level role of an account. Distinct from PermissionRole,
/// which is the dynamic, per-organisation role the admin defines.
enum SystemRole {
  ADMIN
  MANAGER
  SUPERVISOR
  COMPANY_USER
}

/// Whether the account can log in. Admin-controlled.
enum UserStatus {
  ENABLED
  BLOCKED
}

/// What kind of scheduled visit this row represents.
/// REGULAR    — generated as part of a supervisor's monthly schedule
/// ADDITIONAL — ad-hoc, assigned by a manager outside the schedule
enum ScheduledVisitType {
  REGULAR
  ADDITIONAL
}

/// Lifecycle of a single visit instance (V1 / V2 / V3 / V4).
enum VisitStatus {
  REMAINING       // no action yet (default)
  UNDERWAY        // started but not finished
  IMPLEMENTED     // completed
  NOT_IMPLEMENTED // skipped with a reason
  FINAL_CLOSED    // branch permanently closed; cascades to remaining V's
}

/// Whether the branch manager has documented this visit.
enum DocumentationStatus {
  DOCUMENTED
  UNDOCUMENTED
}

// ============================================
// IDENTITY & ACCESS — Phase 1
// ============================================
// Naming conventions used throughout this schema:
//   - Model names: PascalCase, singular (User, not Users)
//   - Field names: camelCase in code, snake_case in DB via @map
//   - Table names: snake_case plural via @@map
// ============================================

/// Every account in the platform — admins, managers, supervisors,
/// and company users — lives in this single table. Role-specific
/// behaviour is decided at the service layer based on `role`.
model User {
  id       String     @id @default(cuid())
  email    String     @unique
  phone    String?    @unique
  password String // bcrypt hash, never plaintext
  role     SystemRole
  status   UserStatus @default(ENABLED)

  // Bilingual display name
  nameAr String  @map("name_ar")
  nameEn String? @map("name_en")

  // Optional dynamic permission role (only meaningful for ADMIN / MANAGER).
  // Supervisors and company users have fixed capabilities and leave this NULL.
  permissionRoleId String?         @map("permission_role_id")
  permissionRole   PermissionRole? @relation(fields: [permissionRoleId], references: [id])

  // Set only when role = COMPANY_USER. Links the login account to the
  // company entity it represents.
  companyId String?  @map("company_id")
  company   Company? @relation(fields: [companyId], references: [id])

  refreshTokens     RefreshToken[]
  monthlySchedules  MonthlySchedule[]
  assignedTasks     ScheduledVisit[]  @relation("AssignedByManager")
  receivedTasks     ScheduledVisit[]  @relation("AssignedToSupervisor")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([role])
  @@index([deletedAt])
  @@index([companyId])
  @@map("users")
}

/// A named bundle of permissions. Created and managed by admins.
/// Examples: "Reports Admin", "Sales Manager", "Full Admin".
model PermissionRole {
  id          String     @id @default(cuid())
  name        String
  description String?
  /// Which kind of user this role can be assigned to (ADMIN or MANAGER).
  appliesTo   SystemRole @map("applies_to")

  users       User[]
  permissions PermissionRolePermission[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("permission_roles")
}

/// The static catalog of capabilities that can be granted to a PermissionRole.
/// Seeded at deploy time, not user-managed at runtime.
/// Example keys: 'MANAGE_SUPERVISORS', 'EXPORT_REPORTS', 'VIEW_SALES'.
model Permission {
  id            String  @id @default(cuid())
  key           String  @unique
  descriptionAr String  @map("description_ar")
  descriptionEn String? @map("description_en")
  /// Which feature module this permission belongs to (e.g. 'supervisors').
  module        String

  roles PermissionRolePermission[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("permissions")
}

/// Many-to-many join between PermissionRole and Permission.
model PermissionRolePermission {
  permissionRoleId String @map("permission_role_id")
  permissionId     String @map("permission_id")

  permissionRole PermissionRole @relation(fields: [permissionRoleId], references: [id], onDelete: Cascade)
  permission     Permission     @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([permissionRoleId, permissionId])
  @@map("permission_role_permissions")
}

/// One row per active session per device. The plain refresh token is sent
/// to the client; only the SHA-256 hash is stored here so a DB leak does
/// not let an attacker hijack sessions.
///
/// On logout: revokedAt = now(). On token rotation: old row revoked,
/// new row inserted.
model RefreshToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  deviceInfo String?   @map("device_info") // user-agent or app version
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================
// CATALOG — Phase 2 (lookups referenced by branches & visits)
// ============================================

/// Geographic region. Cities and branches reference it.
model Region {
  id     String @id @default(cuid())
  nameAr String @map("name_ar")
  nameEn String? @map("name_en")

  cities   City[]
  branches Branch[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("regions")
}

/// City within a region. Branches reference both region and city.
model City {
  id       String @id @default(cuid())
  regionId String @map("region_id")
  region   Region @relation(fields: [regionId], references: [id])
  nameAr   String @map("name_ar")
  nameEn   String? @map("name_en")

  branches Branch[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([regionId])
  @@index([deletedAt])
  @@map("cities")
}

/// Admin-managed list of reasons a supervisor can pick when marking a
/// visit as "Not Implemented". Visit instances FK into this table.
model NotImplementedReason {
  id      String @id @default(cuid())
  titleAr String @map("title_ar")
  titleEn String? @map("title_en")

  visitInstances VisitInstance[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("not_implemented_reasons")
}

// ============================================
// COMPANIES & BRANCHES — Phase 3
// ============================================

/// Client organisation that owns one or more branches we visit.
/// Has a single login account (User with role=COMPANY_USER) created
/// atomically with the Company.
model Company {
  id     String  @id @default(cuid())
  nameAr String  @map("name_ar")
  nameEn String? @map("name_en")

  /// Optional contact info for the company entity itself
  /// (different from the login user's email/phone).
  contactEmail String? @map("contact_email")
  contactPhone String? @map("contact_phone")

  loginUsers User[]
  branches   Branch[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("companies")
}

/// Branch category (e.g. "Hypermarket", "Express", "Pharmacy").
/// Optional on branches per FRD §1.2.4.
model Category {
  id     String  @id @default(cuid())
  nameAr String  @map("name_ar")
  nameEn String? @map("name_en")

  branches Branch[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("categories")
}

/// A physical branch belonging to a Company. The unit a supervisor visits.
model Branch {
  id String @id @default(cuid())

  companyId  String  @map("company_id")
  company    Company @relation(fields: [companyId], references: [id])
  categoryId String? @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id])
  regionId   String  @map("region_id")
  region     Region  @relation(fields: [regionId], references: [id])
  cityId     String  @map("city_id")
  city       City    @relation(fields: [cityId], references: [id])

  nameAr       String  @map("name_ar")
  nameEn       String? @map("name_en")
  branchNumber String? @map("branch_number")
  code         String?
  addressAr    String? @map("address_ar")
  addressEn    String? @map("address_en")
  latitude     Decimal?
  longitude    Decimal?

  /// 1..4 — drives schedule generation in Phase 4.
  visitsPerMonth Int @default(1) @map("visits_per_month")

  requiredTasks   BranchRequiredTask[]
  scheduledVisits ScheduledVisit[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([companyId])
  @@index([regionId])
  @@index([cityId])
  @@index([code])
  @@index([deletedAt])
  @@map("branches")
}

/// Tasks the supervisor must complete during a visit of a given visit type
/// at a specific branch. (V1 of branch X has a different list than V2.)
model BranchRequiredTask {
  id        String @id @default(cuid())
  branchId  String @map("branch_id")
  branch    Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  visitType Int    @map("visit_type") // 1=V1, 2=V2, 3=V3, 4=V4
  titleAr   String @map("title_ar")
  titleEn   String? @map("title_en")
  sortOrder Int    @default(0) @map("sort_order")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([branchId, visitType])
  @@map("branch_required_tasks")
}

// Add the inverse of Region/City relations to branches (Prisma needs this)
// Region.branches and City.branches are added below via separate model edits.

// ============================================
// SCHEDULING & VISIT EXECUTION — Phase 4
// ============================================

/// One per (supervisor, year, month). Holds the supervisor's full
/// schedule of branch visits for that month. Drafts have publishedAt
/// = NULL; once the admin "publishes", supervisors can see the schedule.
model MonthlySchedule {
  id           String @id @default(cuid())
  supervisorId String @map("supervisor_id")
  supervisor   User   @relation(fields: [supervisorId], references: [id])
  year         Int
  month        Int     // 1..12
  publishedAt  DateTime? @map("published_at")

  scheduledVisits ScheduledVisit[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([supervisorId, year, month])
  @@index([deletedAt])
  @@map("monthly_schedules")
}

/// Admin's input level. One row per (branch, schedule) for REGULAR
/// type, or per ad-hoc assignment for ADDITIONAL type.
/// The system generates one VisitInstance per V1/V2/V3/V4 from this row.
model ScheduledVisit {
  id   String             @id @default(cuid())
  type ScheduledVisitType

  /// REGULAR: required link to the schedule. ADDITIONAL: NULL.
  monthlyScheduleId String?          @map("monthly_schedule_id")
  monthlySchedule   MonthlySchedule? @relation(fields: [monthlyScheduleId], references: [id], onDelete: Cascade)

  /// ADDITIONAL only: who assigned and to whom.
  assignedByManagerId    String? @map("assigned_by_manager_id")
  assignedByManager      User?   @relation("AssignedByManager", fields: [assignedByManagerId], references: [id])
  assignedToSupervisorId String? @map("assigned_to_supervisor_id")
  assignedToSupervisor   User?   @relation("AssignedToSupervisor", fields: [assignedToSupervisorId], references: [id])

  branchId       String   @map("branch_id")
  branch         Branch   @relation(fields: [branchId], references: [id])
  numberOfVisits Int      @default(1) @map("number_of_visits")
  firstVisitDate DateTime @map("first_visit_date") @db.Date

  /// ADDITIONAL only: extra metadata.
  price Decimal?
  notes String?

  visitInstances VisitInstance[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([monthlyScheduleId])
  @@index([branchId])
  @@index([type])
  @@index([assignedToSupervisorId])
  @@index([deletedAt])
  @@map("scheduled_visits")
}

/// One per V1, V2, V3, V4 — the actual unit a supervisor visits.
/// Status transitions are enforced in the service layer; once a
/// terminal status is reached, locked_at is set and updates are refused.
model VisitInstance {
  id               String         @id @default(cuid())
  scheduledVisitId String         @map("scheduled_visit_id")
  scheduledVisit   ScheduledVisit @relation(fields: [scheduledVisitId], references: [id], onDelete: Cascade)
  visitOrder       Int            @map("visit_order") // 1=V1, 2=V2, 3=V3, 4=V4
  scheduledDate    DateTime       @map("scheduled_date") @db.Date

  status              VisitStatus         @default(REMAINING)
  documentationStatus DocumentationStatus @default(UNDOCUMENTED) @map("documentation_status")

  notImplementedReasonId String?               @map("not_implemented_reason_id")
  notImplementedReason   NotImplementedReason? @relation(fields: [notImplementedReasonId], references: [id])

  /// Recorded automatically when the supervisor starts/finishes the visit.
  startedAt       DateTime? @map("started_at")
  endedAt         DateTime? @map("ended_at")
  durationSeconds Int?      @map("duration_seconds")

  /// GPS captured at start.
  startLatitude  Decimal? @map("start_latitude")
  startLongitude Decimal? @map("start_longitude")

  /// For OTP-based documentation flow.
  branchManagerPhone String? @map("branch_manager_phone")

  /// Set when status reaches a terminal state. The service layer
  /// refuses any update if locked_at IS NOT NULL.
  lockedAt DateTime? @map("locked_at")

  /// If this instance was auto-created because an earlier V was marked
  /// FINAL_CLOSED, point to the source instance.
  cascadedFromVisitInstanceId String?         @map("cascaded_from_visit_instance_id")
  cascadedFromVisitInstance   VisitInstance?  @relation("VisitCascade", fields: [cascadedFromVisitInstanceId], references: [id])
  cascadedTo                  VisitInstance[] @relation("VisitCascade")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([scheduledVisitId, visitOrder])
  @@index([scheduledDate])
  @@index([status])
  @@index([lockedAt])
  @@index([deletedAt])
  @@map("visit_instances")
}

// ============================================
// SYSTEM
// ============================================

/// Simple key/value store for platform-wide settings.
/// Example keys: "maintenance_mode", "default_sms_sender".
model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

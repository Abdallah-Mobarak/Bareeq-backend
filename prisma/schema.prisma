// ============================================
// Prisma Schema — Bareeq Backend
// ============================================
// Docs: https://www.prisma.io/docs
// After any change here, run:  npm run prisma:migrate
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

/// The system-level role of an account. Distinct from PermissionRole,
/// which is the dynamic, per-organisation role the admin defines.
enum SystemRole {
  ADMIN
  MANAGER
  SUPERVISOR
  COMPANY_USER
  ACCOUNTANT_MANAGER
  CUSTOMER
  SERVICE_PROVIDER
}

/// KYC / verification state for a ServiceProvider account.
/// NOT_SUBMITTED → freshly signed up, no docs yet.
/// PENDING       → docs uploaded, admin review queued.
/// APPROVED      → admin verified; SP can accept bookings.
/// REJECTED      → admin rejected; SP must resubmit.
enum KycStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

/// Whether the account can log in. Admin-controlled.
enum UserStatus {
  ENABLED
  BLOCKED
}

/// What kind of scheduled visit this row represents.
/// REGULAR    — generated as part of a supervisor's monthly schedule
/// ADDITIONAL — ad-hoc, assigned by a manager outside the schedule
enum ScheduledVisitType {
  REGULAR
  ADDITIONAL
}

/// Lifecycle of a single visit instance (V1 / V2 / V3 / V4).
enum VisitStatus {
  REMAINING // no action yet (default)
  UNDERWAY // started but not finished
  IMPLEMENTED // completed
  NOT_IMPLEMENTED // skipped with a reason
  FINAL_CLOSED // branch permanently closed; cascades to remaining V's
}

/// Whether the branch manager has documented this visit.
enum DocumentationStatus {
  DOCUMENTED
  UNDOCUMENTED
}

/// Lifecycle of a Contact-Us message from a Company / AM user to admins.
/// PENDING → freshly sent, awaiting admin response.
/// REPLIED → admin has filled in `reply` and `repliedAt`.
enum ContactMessageStatus {
  PENDING
  REPLIED
}

/// What a OneTimeCode is verifying. Lets us route one shared table to
/// multiple flows without entangling them (Marketplace §1.1, §2.1).
enum OneTimeCodePurpose {
  CUSTOMER_SIGNUP
  SERVICE_PROVIDER_SIGNUP
  CUSTOMER_PASSWORD_RESET
  SERVICE_PROVIDER_PASSWORD_RESET
}

/// Lifecycle of a marketplace Booking (FRD §1.3, §2.3).
/// PENDING     → customer created; no SP has accepted yet.
/// APPROVED    → an SP accepted; assignment is locked + commission frozen.
/// IN_PROGRESS → SP marked the work started.
/// COMPLETED   → SP marked the work done.
/// CANCELLED   → customer cancelled while still PENDING.
/// REJECTED    → expired in the pool / admin rejected (Sprint 4+ extension).
enum BookingStatus {
  PENDING
  APPROVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REJECTED
}

/// How the customer chose to pay (§1.2.2.1). MVP supports CASH only;
/// WALLET + ONLINE land with the payment integration in Sprint 4.
enum BookingPaymentMethod {
  CASH
  WALLET
  ONLINE
}

/// Where the booking is in its payment lifecycle. PAID is set on
/// completion for CASH, on charge for WALLET / ONLINE.
enum BookingPaymentStatus {
  PENDING
  PAID
  REFUNDED
}

// ============================================
// IDENTITY & ACCESS — Phase 1
// ============================================
// Naming conventions used throughout this schema:
//   - Model names: PascalCase, singular (User, not Users)
//   - Field names: camelCase in code, snake_case in DB via @map
//   - Table names: snake_case plural via @@map
// ============================================

/// Every account in the platform — admins, managers, supervisors,
/// and company users — lives in this single table. Role-specific
/// behaviour is decided at the service layer based on `role`.
model User {
  id       String     @id @default(cuid())
  email    String     @unique
  phone    String?    @unique
  password String // bcrypt hash, never plaintext
  role     SystemRole
  status   UserStatus @default(ENABLED)

  // Bilingual display name
  nameAr String  @map("name_ar")
  nameEn String? @map("name_en")

  // Optional dynamic permission role (only meaningful for ADMIN / MANAGER).
  // Supervisors and company users have fixed capabilities and leave this NULL.
  permissionRoleId String?         @map("permission_role_id")
  permissionRole   PermissionRole? @relation(fields: [permissionRoleId], references: [id])

  // Set when role = COMPANY_USER (the company login account itself) OR
  // role = ACCOUNTANT_MANAGER (the AM's parent company).
  companyId String?  @map("company_id")
  company   Company? @relation(fields: [companyId], references: [id])

  /// ACCOUNTANT_MANAGER only.
  /// true  → AM has access to ALL region schedulings whose companyName
  ///         matches their parent company's nameAr.
  /// false → AM is limited to the explicit rows in
  ///         accountant_manager_region_schedulings.
  /// Ignored for any other role.
  assignedToAllBranches Boolean @default(false) @map("assigned_to_all_branches")

  refreshTokens               RefreshToken[]
  monthlySchedules            MonthlySchedule[]
  assignedTasks               ScheduledVisit[]                    @relation("AssignedByManager")
  receivedTasks               ScheduledVisit[]                    @relation("AssignedToSupervisor")
  accountantBranchAssignments AccountantManagerRegionScheduling[]
  managerTasks                ManagerTask[]                       @relation("AssignedToManager")
  contactMessagesSent         ContactMessage[]                    @relation("ContactMessageSender")
  contactMessagesReplied      ContactMessage[]                    @relation("ContactMessageAdmin")
  additionalTasksAssigned     AdditionalTask[]                    @relation("AdditionalTaskAssignedBy")
  additionalTasksReceived     AdditionalTask[]                    @relation("AdditionalTaskAssignedTo")
  clients                     Client[]                            @relation("ClientCreatedBy")
  carCasesCreated             CarCase[]                           @relation("CarCaseCreatedBy")
  carCasesAssigned            CarCase[]                           @relation("CarCaseSupervisor")
  representatives             Representative[]                    @relation("RepresentativeCreatedBy")

  // Marketplace satellites — populated only when role is CUSTOMER /
  // SERVICE_PROVIDER. NULL for management-system users.
  customer        Customer?
  serviceProvider ServiceProvider?

  // Marketplace bookings — customer creates them, SP gets assigned
  // when they accept (so assignedSpId is also a User FK).
  bookingsAsCustomer Booking[] @relation("BookingCustomer")
  bookingsAsSp       Booking[] @relation("BookingSp")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([role])
  @@index([deletedAt])
  @@index([companyId])
  @@map("users")
}

/// A named bundle of permissions. Created and managed by admins.
/// FRD §4.2.1.2 / §4.2.3.2: only `name` + selected permissions are
/// captured. The role is not pre-bound to a user type — when the admin
/// creates a manager or admin (FRD §4.2.1.1.2 / §4.2.3.1.2), they pick
/// any role from a single unified list.
model PermissionRole {
  id   String @id @default(cuid())
  name String @unique

  users       User[]
  permissions PermissionRolePermission[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("permission_roles")
}

/// The static catalog of capabilities that can be granted to a PermissionRole.
/// Seeded at deploy time, not user-managed at runtime.
/// Example keys: 'MANAGE_SUPERVISORS', 'EXPORT_REPORTS', 'VIEW_SALES'.
model Permission {
  id            String  @id @default(cuid())
  key           String  @unique
  descriptionAr String  @map("description_ar")
  descriptionEn String? @map("description_en")
  /// Which feature module this permission belongs to (e.g. 'supervisors').
  module        String

  roles PermissionRolePermission[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("permissions")
}

/// Many-to-many join between PermissionRole and Permission.
model PermissionRolePermission {
  permissionRoleId String @map("permission_role_id")
  permissionId     String @map("permission_id")

  permissionRole PermissionRole @relation(fields: [permissionRoleId], references: [id], onDelete: Cascade)
  permission     Permission     @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([permissionRoleId, permissionId])
  @@map("permission_role_permissions")
}

/// One row per active session per device. The plain refresh token is sent
/// to the client; only the SHA-256 hash is stored here so a DB leak does
/// not let an attacker hijack sessions.
///
/// On logout: revokedAt = now(). On token rotation: old row revoked,
/// new row inserted.
model RefreshToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  deviceInfo String?   @map("device_info") // user-agent or app version
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================
// CATALOG — Phase 2 (lookups referenced by branches & visits)
// ============================================

/// Geographic region. Cities and branches reference it.
model Region {
  id     String  @id @default(cuid())
  nameAr String  @map("name_ar")
  nameEn String? @map("name_en")

  cities   City[]
  branches Branch[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("regions")
}

/// City within a region. Branches reference both region and city.
model City {
  id       String  @id @default(cuid())
  regionId String  @map("region_id")
  region   Region  @relation(fields: [regionId], references: [id])
  nameAr   String  @map("name_ar")
  nameEn   String? @map("name_en")

  branches Branch[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([regionId])
  @@index([deletedAt])
  @@map("cities")
}

/// Admin-managed list of reasons a supervisor can pick when marking a
/// visit as "Not Implemented". Visit instances FK into this table.
model NotImplementedReason {
  id      String  @id @default(cuid())
  titleAr String  @map("title_ar")
  titleEn String? @map("title_en")

  visitInstances VisitInstance[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("not_implemented_reasons")
}

// ============================================
// REGION SCHEDULING — FRD §4.2.2.2.1
// ============================================
// RegionScheduling is a STANDALONE entity. Its company/city/region/
// category fields are denormalised STRINGS — they do NOT FK into the
// Companies/Cities/Regions/Categories catalog tables. The admin enters
// them directly (typically via Excel import). This is intentional per
// FRD §4.2.2.2.1; do not "improve" by switching to FKs.
// ============================================

/// One row per (branch + visit blueprint) the admin wants supervisors
/// to visit. The actual visit instances (V1..V4) are generated later
/// when an admin assigns a supervisor and a start date.
model RegionScheduling {
  id             String   @id @default(cuid())
  companyName    String   @map("company_name")
  branchName     String   @map("branch_name")
  categoryName   String?  @map("category_name")
  branchNumber   String?  @map("branch_number")
  city           String
  region         String
  address        String?
  /// Free-text location field. The admin pastes a Google Maps link
  /// or "lat,lng" string here; the service parses out latitude /
  /// longitude on save and keeps the original text for display.
  location       String?
  latitude       Decimal?
  longitude      Decimal?
  /// 1..4 — drives how many V's are generated and the visit-type list.
  numberOfVisits Int      @default(1) @map("number_of_visits")
  code           String?

  requiredTasks         RegionSchedulingTask[]
  scheduledVisits       ScheduledVisit[]
  accountantAssignments AccountantManagerRegionScheduling[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([companyName])
  @@index([city])
  @@index([region])
  @@index([code])
  @@index([deletedAt])
  @@map("region_schedulings")
}

/// Tasks the supervisor must complete during a specific visit type
/// (V1/V2/V3/V4) of a region scheduling record. Bilingual.
model RegionSchedulingTask {
  id                 String           @id @default(cuid())
  regionSchedulingId String           @map("region_scheduling_id")
  regionScheduling   RegionScheduling @relation(fields: [regionSchedulingId], references: [id], onDelete: Cascade)
  /// 1=V1, 2=V2, 3=V3, 4=V4
  visitType          Int              @map("visit_type")
  titleAr            String           @map("title_ar")
  titleEn            String?          @map("title_en")
  sortOrder          Int              @default(0) @map("sort_order")

  /// Per-visit instances of this task that the supervisor checks off.
  visitChecks VisitInstanceTaskCheck[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([regionSchedulingId, visitType])
  @@map("region_scheduling_tasks")
}

/// M:N between an Accountant Manager (User with role=ACCOUNTANT_MANAGER)
/// and the region schedulings they're explicitly granted access to.
/// Only consulted when the user's `assignedToAllBranches` is false.
model AccountantManagerRegionScheduling {
  userId             String @map("user_id")
  regionSchedulingId String @map("region_scheduling_id")

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  regionScheduling RegionScheduling @relation(fields: [regionSchedulingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@id([userId, regionSchedulingId])
  @@index([regionSchedulingId])
  @@map("accountant_manager_region_schedulings")
}

// ============================================
// MANAGER TASKS — FRD §4.2.1.3
// ============================================

/// Admin-assigned to-dos for a specific manager. The manager toggles
/// `done` to indicate completion. Pure todo list — no scheduling.
model ManagerTask {
  id          String  @id @default(cuid())
  managerId   String  @map("manager_id")
  manager     User    @relation("AssignedToManager", fields: [managerId], references: [id], onDelete: Cascade)
  title       String
  description String?
  done        Boolean @default(false)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([managerId])
  @@index([done])
  @@index([deletedAt])
  @@map("manager_tasks")
}

// ============================================
// CONTACT-US MESSAGES — FRD §2.4 + §4.12 + FR-63 → FR-68
// ============================================

/// A message sent from a COMPANY_USER or ACCOUNTANT_MANAGER to admins
/// through the in-app Contact form. The admin sees the list in §4.12
/// and may reply; the user then pulls /company/contact/my-messages and
/// reads the reply (or receives a notification when we wire that up).
///
/// We store `email` and `phone` separately from the User.email/phone
/// because FR-65 explicitly asks the sender to fill them in on the
/// form, which suggests they may differ from the login identity
/// (e.g. a company assistant filing a ticket on someone's behalf).
model ContactMessage {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation("ContactMessageSender", fields: [userId], references: [id], onDelete: Cascade)

  email   String
  phone   String
  message String

  status ContactMessageStatus @default(PENDING)

  // Admin reply — populated only after an admin acts. Null until then.
  reply            String?
  repliedAt        DateTime? @map("replied_at")
  repliedByAdminId String?   @map("replied_by_admin_id")
  repliedBy        User?     @relation("ContactMessageAdmin", fields: [repliedByAdminId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("contact_messages")
}

// ============================================
// ADDITIONAL TASKS — FRD §1.4 + §3.9
// ============================================

/// Manager-assigned ad-hoc visits, outside the regular monthly schedule.
/// Unlike a ScheduledVisit which derives its location from RegionScheduling,
/// an AdditionalTask carries its own company / branch / address fields
/// because it can target any place — even one not in the catalog.
///
/// Phase C.1 covers the manager-side CRUD only. The supervisor's visit
/// lifecycle (start / complete / photos / OTP) lands in Phase C.2 and
/// will fill in startedAt / endedAt / documentation fields.
model AdditionalTask {
  id String @id @default(cuid())

  managerId    String @map("manager_id")
  manager      User   @relation("AdditionalTaskAssignedBy", fields: [managerId], references: [id])
  supervisorId String @map("supervisor_id")
  supervisor   User   @relation("AdditionalTaskAssignedTo", fields: [supervisorId], references: [id])

  // Free-text destination — FRD §3.9.2 lists Company / Brand / Address
  // as separate fields, not foreign keys. The manager types them in.
  companyName  String  @map("company_name")
  branchName   String? @map("branch_name")
  categoryName String? @map("category_name")
  address      String
  /// Google Maps URL or lat,lng text — same convention as RegionScheduling.
  location     String?
  latitude     Decimal?
  longitude    Decimal?

  visitDate DateTime @map("visit_date")
  price     Decimal?
  notes     String?

  // Visit state — set by the supervisor in Phase C.2. We default to
  // REMAINING so a freshly-created task is immediately discoverable in
  // the supervisor's pending list.
  status              VisitStatus         @default(REMAINING)
  documentationStatus DocumentationStatus @default(UNDOCUMENTED)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([managerId])
  @@index([supervisorId])
  @@index([visitDate])
  @@index([status])
  @@index([deletedAt])
  @@map("additional_tasks")
}

// ============================================
// MONTHLY SALES / CLIENTS — FRD §3.7 + §4.9
// ============================================

/// Sales contract / client record managed by managers.
///
/// FRD §3.7.2 references three admin-managed lookups:
///   • Contract Type
///   • Tax (Tax Type)
///   • Contract Status
/// For Phase D.1 we store them as free-text strings — the manager UI
/// can ship dropdowns with hard-coded values. When the admin module
/// builds out those lookup tables in a later phase, a migration will
/// convert these to FKs without changing the API contract (the API
/// will accept either an id or the legacy string).
model Client {
  id String @id @default(cuid())

  /// The manager who created the client record. We keep it so future
  /// reports can attribute sales to specific managers per FRD §4.9.1.
  managerId String @map("manager_id")
  manager   User   @relation("ClientCreatedBy", fields: [managerId], references: [id])

  name      String
  statement String?
  website   String?
  price     Decimal?
  date      DateTime
  notes     String?

  // Admin-managed lookups stored as strings until the lookup tables ship.
  contractType   String? @map("contract_type")
  taxType        String? @map("tax_type")
  contractStatus String? @map("contract_status")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([managerId])
  @@index([name])
  @@index([date])
  @@index([contractStatus])
  @@index([deletedAt])
  @@map("clients")
}

// ============================================
// CAR CASES — FRD §3.8 + §4.10
// ============================================

/// Vehicle assignment + condition tracking for supervisors. Each case
/// links a supervisor to a vehicle (license plate) within an area.
///
/// Admin-managed lookups (Area, License Plate, Vehicle Condition) are
/// stored as strings for Phase D.2 — same approach as Client. A later
/// migration will convert them to FKs once the admin module ships
/// the lookup tables.
model CarCase {
  id String @id @default(cuid())

  /// Manager who created the record.
  managerId String @map("manager_id")
  manager   User   @relation("CarCaseCreatedBy", fields: [managerId], references: [id])

  /// Supervisor the vehicle is assigned to (FRD §3.8.2 "Supervisor Name (selectable)").
  supervisorId String @map("supervisor_id")
  supervisor   User   @relation("CarCaseSupervisor", fields: [supervisorId], references: [id])

  // Admin-managed lookups stored as strings until the lookup tables ship.
  area             String  @map("area")
  licensePlate     String  @map("license_plate")
  vehicleCondition String  @map("vehicle_condition")
  oilChangeDate    DateTime? @map("oil_change_date")
  notes            String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([managerId])
  @@index([supervisorId])
  @@index([area])
  @@index([licensePlate])
  @@index([deletedAt])
  @@map("car_cases")
}

// ============================================
// REPRESENTATIVES — FRD §3.10 + §4.11
// ============================================

/// Service agreement with a client. The price is computed by the
/// server from `hourlyRate × numberOfWorkers × numberOfHours` and
/// persisted alongside the inputs so the row is traceable even if
/// the hourly rate later changes.
///
/// FRD §3.10 references a `serviceType` admin-managed lookup that
/// owns the canonical hourly rate. For Phase D.3 we accept the rate
/// directly in the create / update body so managers can record
/// agreements without waiting for the admin module. When that module
/// ships, we'll add a `serviceTypeId` FK and lift the rate out of the
/// payload — the API contract stays additive.
model Representative {
  id String @id @default(cuid())

  /// Manager who created the agreement.
  managerId String @map("manager_id")
  manager   User   @relation("RepresentativeCreatedBy", fields: [managerId], references: [id])

  clientName  String  @map("client_name")
  serviceType String  @map("service_type")

  /// Inputs to the price formula. We keep all three even after computing
  /// `price` so anyone reading the row knows where the number came from.
  hourlyRate      Decimal @map("hourly_rate")
  numberOfWorkers Int     @map("number_of_workers")
  numberOfHours   Decimal @map("number_of_hours")

  /// Computed: hourlyRate * numberOfWorkers * numberOfHours.
  /// Stored (not a view) so historical reports don't drift if the
  /// underlying rate is edited later.
  price Decimal

  dateOfAgreement     DateTime @map("date_of_agreement")
  customerPhoneNumber String?  @map("customer_phone_number")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([managerId])
  @@index([clientName])
  @@index([dateOfAgreement])
  @@index([deletedAt])
  @@map("representatives")
}

// ============================================
// COMPANIES & BRANCHES — Phase 3
// ============================================

/// Client organisation that owns one or more branches we visit.
/// Has a single login account (User with role=COMPANY_USER) created
/// atomically with the Company.
model Company {
  id     String  @id @default(cuid())
  nameAr String  @map("name_ar")
  nameEn String? @map("name_en")

  /// Optional contact info for the company entity itself
  /// (different from the login user's email/phone).
  contactEmail String? @map("contact_email")
  contactPhone String? @map("contact_phone")

  loginUsers User[]
  branches   Branch[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("companies")
}

/// Branch category (e.g. "Hypermarket", "Express", "Pharmacy").
/// Optional on branches per FRD §1.2.4.
model Category {
  id     String  @id @default(cuid())
  nameAr String  @map("name_ar")
  nameEn String? @map("name_en")

  branches Branch[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("categories")
}

/// A physical branch belonging to a Company. The unit a supervisor visits.
model Branch {
  id String @id @default(cuid())

  companyId  String    @map("company_id")
  company    Company   @relation(fields: [companyId], references: [id])
  categoryId String?   @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id])
  regionId   String    @map("region_id")
  region     Region    @relation(fields: [regionId], references: [id])
  cityId     String    @map("city_id")
  city       City      @relation(fields: [cityId], references: [id])

  nameAr       String   @map("name_ar")
  nameEn       String?  @map("name_en")
  branchNumber String?  @map("branch_number")
  code         String?
  addressAr    String?  @map("address_ar")
  addressEn    String?  @map("address_en")
  latitude     Decimal?
  longitude    Decimal?

  /// 1..4 — drives schedule generation in Phase 4.
  visitsPerMonth Int @default(1) @map("visits_per_month")

  requiredTasks BranchRequiredTask[]
  // Note: ScheduledVisit no longer links to Branch — see RegionScheduling
  // (FRD §4.2.2.2.1). Branch is kept as a catalog record for reference
  // and may be removed later if it stays unused.

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([companyId])
  @@index([regionId])
  @@index([cityId])
  @@index([code])
  @@index([deletedAt])
  @@map("branches")
}

/// Tasks the supervisor must complete during a visit of a given visit type
/// at a specific branch. (V1 of branch X has a different list than V2.)
model BranchRequiredTask {
  id        String  @id @default(cuid())
  branchId  String  @map("branch_id")
  branch    Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  visitType Int     @map("visit_type") // 1=V1, 2=V2, 3=V3, 4=V4
  titleAr   String  @map("title_ar")
  titleEn   String? @map("title_en")
  sortOrder Int     @default(0) @map("sort_order")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([branchId, visitType])
  @@map("branch_required_tasks")
}

// Add the inverse of Region/City relations to branches (Prisma needs this)
// Region.branches and City.branches are added below via separate model edits.

// ============================================
// SCHEDULING & VISIT EXECUTION — Phase 4
// ============================================

/// One per (supervisor, year, month). Holds the supervisor's full
/// schedule of branch visits for that month. Drafts have publishedAt
/// = NULL; once the admin "publishes", supervisors can see the schedule.
model MonthlySchedule {
  id           String    @id @default(cuid())
  supervisorId String    @map("supervisor_id")
  supervisor   User      @relation(fields: [supervisorId], references: [id])
  year         Int
  month        Int // 1..12
  publishedAt  DateTime? @map("published_at")

  scheduledVisits ScheduledVisit[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([supervisorId, year, month])
  @@index([deletedAt])
  @@map("monthly_schedules")
}

/// Admin's input level. One row per (branch, schedule) for REGULAR
/// type, or per ad-hoc assignment for ADDITIONAL type.
/// The system generates one VisitInstance per V1/V2/V3/V4 from this row.
model ScheduledVisit {
  id   String             @id @default(cuid())
  type ScheduledVisitType

  /// REGULAR: required link to the schedule. ADDITIONAL: NULL.
  monthlyScheduleId String?          @map("monthly_schedule_id")
  monthlySchedule   MonthlySchedule? @relation(fields: [monthlyScheduleId], references: [id], onDelete: Cascade)

  /// ADDITIONAL only: who assigned and to whom.
  assignedByManagerId    String? @map("assigned_by_manager_id")
  assignedByManager      User?   @relation("AssignedByManager", fields: [assignedByManagerId], references: [id])
  assignedToSupervisorId String? @map("assigned_to_supervisor_id")
  assignedToSupervisor   User?   @relation("AssignedToSupervisor", fields: [assignedToSupervisorId], references: [id])

  /// FRD §4.2.2.2.1 §3 "Assign Supervisors": admin assigns a supervisor
  /// to one or more region scheduling records. ScheduledVisit links to
  /// the region scheduling, NOT the legacy Branches table.
  regionSchedulingId String           @map("region_scheduling_id")
  regionScheduling   RegionScheduling @relation(fields: [regionSchedulingId], references: [id])
  numberOfVisits     Int              @default(1) @map("number_of_visits")
  firstVisitDate     DateTime         @map("first_visit_date") @db.Date

  /// ADDITIONAL only: extra metadata.
  price Decimal?
  notes String?

  visitInstances VisitInstance[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([monthlyScheduleId])
  @@index([regionSchedulingId])
  @@index([type])
  @@index([assignedToSupervisorId])
  @@index([deletedAt])
  @@map("scheduled_visits")
}

/// One per V1, V2, V3, V4 — the actual unit a supervisor visits.
/// Status transitions are enforced in the service layer; once a
/// terminal status is reached, locked_at is set and updates are refused.
model VisitInstance {
  id               String         @id @default(cuid())
  scheduledVisitId String         @map("scheduled_visit_id")
  scheduledVisit   ScheduledVisit @relation(fields: [scheduledVisitId], references: [id], onDelete: Cascade)
  visitOrder       Int            @map("visit_order") // 1=V1, 2=V2, 3=V3, 4=V4
  scheduledDate    DateTime       @map("scheduled_date") @db.Date

  status              VisitStatus         @default(REMAINING)
  documentationStatus DocumentationStatus @default(UNDOCUMENTED) @map("documentation_status")

  notImplementedReasonId String?               @map("not_implemented_reason_id")
  notImplementedReason   NotImplementedReason? @relation(fields: [notImplementedReasonId], references: [id])

  /// Recorded automatically when the supervisor starts/finishes the visit.
  startedAt       DateTime? @map("started_at")
  endedAt         DateTime? @map("ended_at")
  durationSeconds Int?      @map("duration_seconds")

  /// GPS captured at start.
  startLatitude  Decimal? @map("start_latitude")
  startLongitude Decimal? @map("start_longitude")

  /// For OTP-based documentation flow.
  branchManagerPhone String? @map("branch_manager_phone")

  /// OTP sent to the branch manager so they can document the visit
  /// via a public link (FRD §1.2.3.1 §2.5). Stored as a hash, not
  /// plaintext.
  documentationOtpHash String?   @map("documentation_otp_hash")
  otpExpiresAt         DateTime? @map("otp_expires_at")

  /// Public token used in the URL we send to the branch manager. Long,
  /// random, single-use. Cleared once submission lands.
  documentationToken String? @unique @map("documentation_token")

  /// Branch-manager-provided documentation fields.
  jobNumber    String?   @map("job_number")
  rating       Int? // 1..5, validated at service layer
  comments     String?
  documentedAt DateTime? @map("documented_at")

  /// Set when status reaches a terminal state. The service layer
  /// refuses any update if locked_at IS NOT NULL.
  lockedAt DateTime? @map("locked_at")

  /// If this instance was auto-created because an earlier V was marked
  /// FINAL_CLOSED, point to the source instance.
  cascadedFromVisitInstanceId String?         @map("cascaded_from_visit_instance_id")
  cascadedFromVisitInstance   VisitInstance?  @relation("VisitCascade", fields: [cascadedFromVisitInstanceId], references: [id])
  cascadedTo                  VisitInstance[] @relation("VisitCascade")

  photos     VisitInstancePhoto[]
  taskChecks VisitInstanceTaskCheck[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([scheduledVisitId, visitOrder])
  @@index([scheduledDate])
  @@index([status])
  @@index([lockedAt])
  @@index([deletedAt])
  @@map("visit_instances")
}

/// Photos uploaded during a visit (FRD §1.2.3.1 §2.3).
/// Optional 3–4 per visit; service layer enforces the cap.
model VisitInstancePhoto {
  id              String        @id @default(cuid())
  visitInstanceId String        @map("visit_instance_id")
  visitInstance   VisitInstance @relation(fields: [visitInstanceId], references: [id], onDelete: Cascade)
  url             String
  sizeBytes       Int?          @map("size_bytes")
  mimeType        String?       @map("mime_type")
  uploadedAt      DateTime      @default(now()) @map("uploaded_at")
  deletedAt       DateTime?     @map("deleted_at")

  @@index([visitInstanceId])
  @@map("visit_instance_photos")
}

/// Per-visit checklist of the required tasks. We snapshot the task
/// titles (titleAr/titleEn) at creation time so renames on
/// RegionSchedulingTask don't rewrite history.
model VisitInstanceTaskCheck {
  id              String        @id @default(cuid())
  visitInstanceId String        @map("visit_instance_id")
  visitInstance   VisitInstance @relation(fields: [visitInstanceId], references: [id], onDelete: Cascade)

  /// Source task (kept for traceability; nullable so deleting a task
  /// definition doesn't orphan past records).
  regionSchedulingTaskId String?               @map("region_scheduling_task_id")
  regionSchedulingTask   RegionSchedulingTask? @relation(fields: [regionSchedulingTaskId], references: [id])

  titleAr String  @map("title_ar")
  titleEn String? @map("title_en")
  done    Boolean @default(false)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([visitInstanceId])
  @@map("visit_instance_task_checks")
}

// ============================================
// SYSTEM
// ============================================

/// Simple key/value store for platform-wide settings.
/// Example keys: "maintenance_mode", "default_sms_sender".
model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ============================================
// MARKETPLACE — Phase 4 / Sprint 3
// ============================================
// Satellite tables for marketplace-specific data. The User row holds
// auth (email/password/status); these tables hold business-domain
// fields. 1:1 with User via `userId`. onDelete: Cascade — deleting
// the auth account removes the marketplace profile too.
// ============================================

/// A Customer is a marketplace buyer. Account self-created via
/// /auth/customer/signup with email-OTP verification (FRD §1.1).
model Customer {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  profilePicture String? @map("profile_picture")

  /// In-app wallet balance, used Sprint 4 (FRD §1.1 Wallet Balance Setup).
  /// Decimal(12,2) gives 10 integer digits + 2 fractional — enough for SAR.
  walletBalance Decimal @default(0) @db.Decimal(12, 2) @map("wallet_balance")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("customers")
}

/// A ServiceProvider is a marketplace seller. Account self-created via
/// /auth/service-provider/signup with email-OTP verification (FRD §2.1).
/// Bookings, service offerings, and ratings are wired Sprint 4.
model ServiceProvider {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  profilePicture String? @map("profile_picture")
  bio            String?

  // ── KYC / verification (Sprint 4 admin review flow) ────────────────
  /// Convenience flag derived from kycStatus = APPROVED. Kept as its
  /// own column so list queries don't have to compare enums.
  isVerified Boolean   @default(false) @map("is_verified")
  kycStatus  KycStatus @default(NOT_SUBMITTED) @map("kyc_status")
  verifiedAt DateTime? @map("verified_at")

  // ── Financials (Sprint 4) ──────────────────────────────────────────
  walletBalance Decimal @default(0) @db.Decimal(12, 2) @map("wallet_balance")

  // ── Ratings (Sprint 4, denormalised for fast list display) ─────────
  /// Average over all reviews. NULL until first review.
  ratingAverage Decimal? @db.Decimal(3, 2) @map("rating_average")
  ratingCount   Int      @default(0) @map("rating_count")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([kycStatus])
  @@index([isVerified])
  @@index([deletedAt])
  @@map("service_providers")
}

/// Short-lived verification code (e.g. signup OTP, password-reset OTP).
/// Verifies an *identifier* (email/phone), not a user — so it works
/// before the User row exists. Deliberately not related to User.
///
/// Why a hash, not the code: if the DB is ever leaked, codes stay private.
/// Why `consumedAt` instead of deleting: audit trail (did the user verify?).
/// Why `attempts`: cheap brute-force defence — invalidate after N tries.
model OneTimeCode {
  id         String             @id @default(cuid())
  identifier String // email or phone the OTP was delivered to
  codeHash   String             @map("code_hash") // bcrypt hash, never plaintext
  purpose    OneTimeCodePurpose
  expiresAt  DateTime           @map("expires_at")
  consumedAt DateTime?          @map("consumed_at") // single-use; null until verified
  attempts   Int                @default(0)
  createdAt  DateTime           @default(now()) @map("created_at")

  @@index([identifier, purpose])
  @@index([expiresAt])
  @@map("one_time_codes")
}

// ============================================
// MARKETPLACE CATALOG — Sprint 3
// ============================================
// FRD §3.4 (admin) and §1.2 (customer home).
//
// Three-level hierarchy:
//   ServiceCategory  →  Service  →  ServiceSubcategory
//
// Cost lives ONLY on Subcategory. The "Service Cost" the customer
// sees on a service tile is the sum of selected subcategories
// (§1.2.1 + §1.2.2). The server computes it; it is never stored on
// Service itself — keeping a single source of truth.
//
// Naming: prefixed "Service*" to avoid collision with the existing
// `Category` model used by branches in the Management System.
// ============================================

/// Top-level grouping shown on the customer home (§1.2.3 "View Categories").
/// Manages by admin (the FRD does not name a separate "Categories
/// Management" section, but §1.2.3 lists Name + Icon as customer-visible,
/// so the admin must be able to create/edit them — we infer §3.4 covers it).
model ServiceCategory {
  id        String  @id @default(cuid())
  titleAr   String  @map("title_ar")
  titleEn   String? @map("title_en")
  iconUrl   String? @map("icon_url")
  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  services Service[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([isActive, deletedAt])
  @@index([sortOrder])
  @@map("service_categories")
}

/// A marketplace service (e.g. "Plumbing") — admin-managed via §3.4.1.
/// Belongs to one ServiceCategory. Its price is *not* stored here; it
/// is computed at request time as the sum of its (selected) subcategories.
model Service {
  id            String  @id @default(cuid())
  categoryId    String  @map("category_id")
  category      ServiceCategory @relation(fields: [categoryId], references: [id])

  titleAr       String  @map("title_ar")
  titleEn       String? @map("title_en")
  descriptionAr String? @map("description_ar")
  descriptionEn String? @map("description_en")
  imageUrl      String? @map("image_url")

  /// Per-service commission rate in percent (FRD §3.4.1.5). Admin sets
  /// this; payouts deduct it at booking-settlement time (Sprint 4).
  commissionRate Decimal @default(0) @db.Decimal(5, 2) @map("commission_rate")

  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  subcategories ServiceSubcategory[]
  bookings      Booking[]

  // Denormalised aggregates from customer reviews (Sprint 4 review flow).
  // Kept on the row so list queries don't have to join + aggregate.
  ratingAverage Decimal? @db.Decimal(3, 2) @map("rating_average")
  ratingCount   Int      @default(0) @map("rating_count")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([categoryId, isActive, deletedAt])
  @@index([sortOrder])
  @@index([ratingAverage])
  @@map("services")
}

/// A line item within a Service. The CUSTOMER picks one or more of these;
/// the total cost displayed is the sum of the picked ones (§1.2.2 +
/// §1.2.4 "Cost Range" filter). Cascade-deleted with the parent Service.
model ServiceSubcategory {
  id        String  @id @default(cuid())
  serviceId String  @map("service_id")
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  titleAr String  @map("title_ar")
  titleEn String? @map("title_en")
  cost    Decimal @db.Decimal(12, 2)

  sortOrder Int @default(0) @map("sort_order")

  bookingSubcategories BookingSubcategory[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([serviceId, deletedAt])
  @@map("service_subcategories")
}

// ============================================
// MARKETPLACE BOOKINGS — Sprint 4 (early start)
// ============================================
// FRD §1.3 (customer booking), §2.2 + §2.3 (SP pool + lifecycle),
// §3.3 (admin oversight).
//
// State machine:
//
//   PENDING ──(SP accepts)──→ APPROVED ──(SP starts)──→ IN_PROGRESS
//      │                                                   │
//      │                                                   ▼
//      ▼                                                COMPLETED
//   CANCELLED        REJECTED  (expired/admin-rejected;
//   (customer)        Sprint 4+)
//
// Subcategories snapshot:
//   Each `BookingSubcategory` row copies titleAr/titleEn/cost from
//   ServiceSubcategory at booking time. So if admin later raises a
//   subcategory's price, that change applies to NEW bookings only —
//   historical totals stay frozen.
//
// Commission lock:
//   On APPROVED the row captures the Service.commissionRate at that
//   moment + computes commissionAmount = totalCost * rate / 100.
//   Admin changing the rate afterwards does NOT retroactively change
//   what the SP owes.
// ============================================

/// A marketplace booking from a Customer for a specific Service.
/// The selected subcategories determine the totalCost (snapshot in
/// BookingSubcategory). Lifecycle is tracked via `status`.
model Booking {
  id String @id @default(cuid())

  // Who, what, when
  customerId String @map("customer_id")
  customer   User   @relation("BookingCustomer", fields: [customerId], references: [id])

  serviceId String  @map("service_id")
  service   Service @relation(fields: [serviceId], references: [id])

  /// NULL until an SP accepts (transitions PENDING → APPROVED).
  /// Once set, it's the locked assignment — no reassignment without
  /// a cancel + new booking.
  assignedSpId String? @map("assigned_sp_id")
  assignedSp   User?   @relation("BookingSp", fields: [assignedSpId], references: [id])

  selectedSubcategories BookingSubcategory[]

  // Request details (captured at creation)
  description     String? @db.Text
  locationLat     Decimal? @db.Decimal(10, 7) @map("location_lat")
  locationLng     Decimal? @db.Decimal(10, 7) @map("location_lng")
  locationAddress String?  @map("location_address")
  scheduledDate   DateTime @map("scheduled_date")

  // Pricing — locked at creation
  totalCost Decimal @db.Decimal(12, 2) @map("total_cost")

  // Commission — locked at APPROVED (NULL while PENDING / CANCELLED)
  commissionRate   Decimal? @db.Decimal(5, 2) @map("commission_rate")
  commissionAmount Decimal? @db.Decimal(12, 2) @map("commission_amount")

  // Status + payment
  status        BookingStatus        @default(PENDING)
  paymentMethod BookingPaymentMethod
  paymentStatus BookingPaymentStatus @default(PENDING)

  // Lifecycle timestamps
  approvedAt         DateTime? @map("approved_at")
  startedAt          DateTime? @map("started_at")
  completedAt        DateTime? @map("completed_at")
  cancelledAt        DateTime? @map("cancelled_at")
  cancellationReason String?   @map("cancellation_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([customerId, status])
  @@index([assignedSpId, status])
  @@index([status, createdAt]) // pool query: PENDING ordered by oldest first
  @@index([serviceId])
  @@map("bookings")
}

/// Snapshot of a subcategory picked at booking time. Cost/title are
/// frozen here so later admin edits to ServiceSubcategory don't bleed
/// retroactively into historical bookings (or their commission math).
model BookingSubcategory {
  id        String  @id @default(cuid())
  bookingId String  @map("booking_id")
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  subcategoryId String             @map("subcategory_id")
  subcategory   ServiceSubcategory @relation(fields: [subcategoryId], references: [id])

  // Frozen at booking time
  titleAr String  @map("title_ar")
  titleEn String? @map("title_en")
  cost    Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([bookingId, subcategoryId])
  @@index([bookingId])
  @@map("booking_subcategories")
}

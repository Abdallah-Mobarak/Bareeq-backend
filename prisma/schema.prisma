// ============================================
// Prisma Schema — Bareeq Backend
// ============================================
// Docs: https://www.prisma.io/docs
// After any change here, run:  npm run prisma:migrate
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

/// The system-level role of an account. Distinct from PermissionRole,
/// which is the dynamic, per-organisation role the admin defines.
enum SystemRole {
  ADMIN
  MANAGER
  SUPERVISOR
  COMPANY_USER
  ACCOUNTANT_MANAGER
  CUSTOMER
  SERVICE_PROVIDER
  /// Dedicated operator of the Services Marketplace dashboard
  /// (Marketplace §3). Isolated from the Management System: this role
  /// only passes requireRole on the marketplace admin modules, never on
  /// the Management System's ADMIN-gated routes.
  MARKETPLACE_ADMIN
}

/// KYC / verification state for a ServiceProvider account.
/// NOT_SUBMITTED → freshly signed up, no docs yet.
/// PENDING       → docs uploaded, admin review queued.
/// APPROVED      → admin verified; SP can accept bookings.
/// REJECTED      → admin rejected; SP must resubmit.
enum KycStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

/// Whether the account can log in. Admin-controlled.
enum UserStatus {
  ENABLED
  BLOCKED
}

/// What kind of scheduled visit this row represents.
/// REGULAR    — generated as part of a supervisor's monthly schedule
/// ADDITIONAL — ad-hoc, assigned by a manager outside the schedule
enum ScheduledVisitType {
  REGULAR
  ADDITIONAL
}

/// Lifecycle of a single visit instance (V1 / V2 / V3 / V4).
enum VisitStatus {
  REMAINING // no action yet (default)
  UNDERWAY // started but not finished
  IMPLEMENTED // completed
  NOT_IMPLEMENTED // skipped with a reason
  FINAL_CLOSED // branch permanently closed; cascades to remaining V's
}

/// Whether the branch manager has documented this visit.
enum DocumentationStatus {
  DOCUMENTED
  UNDOCUMENTED
}

/// Lifecycle of a Contact-Us message from a Company / AM user to admins.
/// PENDING → freshly sent, awaiting admin response.
/// REPLIED → admin has filled in `reply` and `repliedAt`.
enum ContactMessageStatus {
  PENDING
  REPLIED
}

/// Lifecycle of a marketplace Dispute (FRD §3.6 marketplace).
/// PENDING    → user submitted; no admin has looked yet.
/// IN_REVIEW  → admin opened it and started investigating.
/// RESOLVED   → admin closed it (typically with a response).
enum DisputeStatus {
  PENDING
  IN_REVIEW
  RESOLVED
}

/// Discriminator for the shared Lookup table — FRD §4.9.2 (Sales Data
/// Management) + §4.10.2 (Care Case Data Management). One row per
/// admin-managed dropdown option; the `type` field tells you which
/// dropdown the row belongs to. Adding a new lookup category later is
/// a one-line enum extension, no new table needed.
enum LookupType {
  CONTRACT_TYPE
  TAX_TYPE
  CONTRACT_STATUS
  AREA
  LICENSE_PLATE
  VEHICLE_CONDITION
}

/// What a OneTimeCode is verifying. Lets us route one shared table to
/// multiple flows without entangling them (Marketplace §1.1, §2.1).
enum OneTimeCodePurpose {
  CUSTOMER_SIGNUP
  SERVICE_PROVIDER_SIGNUP
  CUSTOMER_PASSWORD_RESET
  SERVICE_PROVIDER_PASSWORD_RESET
}

/// Categorises a Notification so the client knows how to render it
/// (icon + deep link). The catalog grows as we wire more events into
/// the notify() helper — adding a value here is a free, non-breaking
/// extension; removing one needs a migration.
enum NotificationType {
  // Auth lifecycle
  CUSTOMER_WELCOME
  SERVICE_PROVIDER_WELCOME
  ACCOUNT_BLOCKED
  ACCOUNT_UNBLOCKED

  // KYC lifecycle (SP)
  KYC_APPROVED
  KYC_REJECTED

  // Booking lifecycle (customer's view)
  BOOKING_ACCEPTED
  BOOKING_STARTED
  BOOKING_COMPLETED
  BOOKING_CANCELLED // customer cancelled a pending request (FRD §1.4)
  REFUND_ISSUED // wallet refunded after a cancellation (FRD §1.4)

  // Booking lifecycle (SP's view)
  NEW_BOOKING_REQUEST // a new request matching the SP's service type entered the pool
  REVIEW_RECEIVED

  // Generic / admin-pushed
  SYSTEM_ANNOUNCEMENT

  // Wallet lifecycle (Sprint 4 e-Wallet)
  TOPUP_RECEIVED

  // Withdrawal lifecycle (Sprint 4 SP cash-out)
  WITHDRAWAL_SUBMITTED // SP's request was received and is under admin review
  WITHDRAWAL_APPROVED
  WITHDRAWAL_REJECTED

  // Dispute lifecycle (FRD §3.6 marketplace)
  DISPUTE_FILED // admin received a new complaint from a user
  DISPUTE_RESPONDED // user received an admin response to their dispute

  // Management system — schedule & visit lifecycle (FRD §1.5 / §2.5)
  SCHEDULE_PUBLISHED // admin published/assigned the monthly schedule
  VISIT_ASSIGNED // a new branch visit was added to the schedule
  VISIT_STATUS_CHANGED // a branch visit status changed (status carried in `data`)
  MONTHLY_REPORT_AVAILABLE // the monthly report is ready to view
  ADDITIONAL_TASK_ASSIGNED // manager assigned a new additional task to a supervisor
  VISIT_MISSED // a scheduled visit passed its date with no action (Not Visited alert)
  CONTACT_REPLIED // admin replied to a contact message
}

/// Lifecycle of a WithdrawalRequest (FRD §3.5.2).
///   PENDING   → SP submitted; awaiting admin review.
///   APPROVED  → admin transferred + wallet debited (WITHDRAWAL txn).
///   REJECTED  → admin denied; no money movement; adminNote captures why.
///   CANCELLED → SP withdrew the request before admin reviewed it.
enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

/// How the SP wants to receive a withdrawal (FRD §2.1 Wallet → Withdrawal
/// Methods). BANK uses bankName/bankAccountIban/accountHolderName; EWALLET
/// uses walletName/walletId. The validation layer enforces the right set
/// per method.
enum WithdrawalMethod {
  BANK
  EWALLET
}

/// Direction + intent of a WalletTransaction. The sign is implied:
///   TOPUP / BOOKING_CREDIT / REFUND       → credit (+amount)
///   BOOKING_DEBIT / WITHDRAWAL /
///   COMMISSION_DEBIT                       → debit  (-amount)
///   ADJUSTMENT                             → either; the admin caller passes a
///                                            signed amount
///
/// `amount` itself is always stored positive — the sign is applied by
/// the wallet service helper based on `type`.
enum WalletTransactionType {
  TOPUP // Customer adds money (admin manual now, PayTabs later)
  BOOKING_DEBIT // Customer pays for a WALLET booking
  REFUND // Money back to customer (cancellation, dispute)
  BOOKING_CREDIT // SP receives gross earnings from a completed WALLET booking
  COMMISSION_DEBIT // Platform takes its cut from the SP's earnings
  WITHDRAWAL // SP cashes out (Sprint 4+ withdrawal flow)
  ADJUSTMENT_CREDIT // Admin manual addition (dispute resolution)
  ADJUSTMENT_DEBIT // Admin manual subtraction
}

/// Lifecycle of a marketplace Booking (FRD §1.3, §2.3).
/// PENDING     → customer created; no SP has accepted yet.
/// APPROVED    → an SP accepted; assignment is locked + commission frozen.
/// IN_PROGRESS → SP marked the work started.
/// COMPLETED   → SP marked the work done.
/// CANCELLED   → customer cancelled while still PENDING.
/// REJECTED    → expired in the pool / admin rejected (Sprint 4+ extension).
enum BookingStatus {
  PENDING
  APPROVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REJECTED
}

/// How the customer chose to pay (§1.2.2.1). MVP supports CASH only;
/// WALLET + ONLINE land with the payment integration in Sprint 4.
enum BookingPaymentMethod {
  CASH
  WALLET
  ONLINE
}

/// Where the booking is in its payment lifecycle. PAID is set on
/// completion for CASH, on charge for WALLET / ONLINE.
enum BookingPaymentStatus {
  PENDING
  PAID
  REFUNDED
}

// ============================================
// IDENTITY & ACCESS — Phase 1
// ============================================
// Naming conventions used throughout this schema:
//   - Model names: PascalCase, singular (User, not Users)
//   - Field names: camelCase in code, snake_case in DB via @map
//   - Table names: snake_case plural via @@map
// ============================================

/// Every account in the platform — admins, managers, supervisors,
/// and company users — lives in this single table. Role-specific
/// behaviour is decided at the service layer based on `role`.
/// UI language preference shown on the mobile profile (App Settings →
/// Arabic / English) for every surface. Defaults to Arabic (Saudi-first).
enum Language {
  AR
  EN
}

model User {
  id       String     @id @default(cuid())
  email    String     @unique
  phone    String?    @unique
  password String // bcrypt hash, never plaintext
  role     SystemRole
  status   UserStatus @default(ENABLED)

  // Bilingual display name
  nameAr String  @map("name_ar")
  nameEn String? @map("name_en")

  /// Preferred UI language (App Settings → Arabic/English on the mobile
  /// profile screens). Stored here so supervisor, company, and every other
  /// surface read the same preference.
  preferredLanguage Language @default(AR) @map("preferred_language")

  // Optional dynamic permission role (only meaningful for ADMIN / MANAGER).
  // Supervisors and company users have fixed capabilities and leave this NULL.
  permissionRoleId String?         @map("permission_role_id")
  permissionRole   PermissionRole? @relation(fields: [permissionRoleId], references: [id])

  // Set when role = COMPANY_USER (the company login account itself) OR
  // role = ACCOUNTANT_MANAGER (the AM's parent company).
  companyId String?  @map("company_id")
  company   Company? @relation(fields: [companyId], references: [id])

  /// ACCOUNTANT_MANAGER only.
  /// true  → AM has access to ALL region schedulings whose companyName
  ///         matches their parent company's nameAr.
  /// false → AM is limited to the explicit rows in
  ///         accountant_manager_region_schedulings.
  /// Ignored for any other role.
  assignedToAllBranches Boolean @default(false) @map("assigned_to_all_branches")

  refreshTokens               RefreshToken[]
  monthlySchedules            MonthlySchedule[]
  assignedTasks               ScheduledVisit[]                    @relation("AssignedByManager")
  receivedTasks               ScheduledVisit[]                    @relation("AssignedToSupervisor")
  accountantBranchAssignments AccountantManagerRegionScheduling[]
  managerTasks                ManagerTask[]                       @relation("AssignedToManager")
  contactMessagesSent         ContactMessage[]                    @relation("ContactMessageSender")
  contactMessagesReplied      ContactMessage[]                    @relation("ContactMessageAdmin")
  additionalTasksAssigned     AdditionalTask[]                    @relation("AdditionalTaskAssignedBy")
  additionalTasksReceived     AdditionalTask[]                    @relation("AdditionalTaskAssignedTo")
  clients                     Client[]                            @relation("ClientCreatedBy")
  carCasesCreated             CarCase[]                           @relation("CarCaseCreatedBy")
  carCasesAssigned            CarCase[]                           @relation("CarCaseSupervisor")
  representatives             Representative[]                    @relation("RepresentativeCreatedBy")

  // Marketplace satellites — populated only when role is CUSTOMER /
  // SERVICE_PROVIDER. NULL for management-system users.
  customer        Customer?
  serviceProvider ServiceProvider?

  // Marketplace bookings — customer creates them, SP gets assigned
  // when they accept (so assignedSpId is also a User FK).
  bookingsAsCustomer Booking[]          @relation("BookingCustomer")
  bookingsAsSp       Booking[]          @relation("BookingSp")
  // Pool requests this SP dismissed ("Reject" on the pending screen).
  bookingDismissals  BookingDismissal[] @relation("BookingDismissalSp")

  // Marketplace reviews — customer authors them; SP gets reviewed.
  reviewsAuthored Review[] @relation("ReviewCustomer")
  reviewsReceived Review[] @relation("ReviewServiceProvider")

  // In-app notifications the user has received.
  notifications Notification[]

  // Wallet ledger — every TOPUP/DEBIT/CREDIT/REFUND etc. for this user.
  walletTransactions WalletTransaction[]

  // Withdrawal requests — SP requests cash-out; admin reviews.
  withdrawalRequests         WithdrawalRequest[] @relation("WithdrawalSp")
  withdrawalRequestsReviewed WithdrawalRequest[] @relation("WithdrawalAdmin")

  // Admin-sent broadcast notifications — one row per "send" event,
  // separate from the per-user `notifications` fan-out.
  notificationBroadcastsSent NotificationBroadcast[] @relation("BroadcastSentByAdmin")

  // Marketplace disputes (FRD §3.6 marketplace). A user files disputes;
  // an admin responds to them.
  disputesFiled     Dispute[] @relation("DisputeFiledBy")
  disputesResponded Dispute[] @relation("DisputeRespondedBy")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([role])
  @@index([deletedAt])
  @@index([companyId])
  @@map("users")
}

/// A named bundle of permissions. Created and managed by admins.
/// FRD §4.2.1.2 / §4.2.3.2: only `name` + selected permissions are
/// captured. The role is not pre-bound to a user type — when the admin
/// creates a manager or admin (FRD §4.2.1.1.2 / §4.2.3.1.2), they pick
/// any role from a single unified list.
model PermissionRole {
  id   String @id @default(cuid())
  name String @unique

  users       User[]
  permissions PermissionRolePermission[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("permission_roles")
}

/// The static catalog of capabilities that can be granted to a PermissionRole.
/// Seeded at deploy time, not user-managed at runtime.
/// Example keys: 'MANAGE_SUPERVISORS', 'EXPORT_REPORTS', 'VIEW_SALES'.
model Permission {
  id            String  @id @default(cuid())
  key           String  @unique
  descriptionAr String  @map("description_ar")
  descriptionEn String? @map("description_en")
  /// Which feature module this permission belongs to (e.g. 'supervisors').
  module        String

  roles PermissionRolePermission[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("permissions")
}

/// Many-to-many join between PermissionRole and Permission.
model PermissionRolePermission {
  permissionRoleId String @map("permission_role_id")
  permissionId     String @map("permission_id")

  permissionRole PermissionRole @relation(fields: [permissionRoleId], references: [id], onDelete: Cascade)
  permission     Permission     @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([permissionRoleId, permissionId])
  @@map("permission_role_permissions")
}

/// One row per active session per device. The plain refresh token is sent
/// to the client; only the SHA-256 hash is stored here so a DB leak does
/// not let an attacker hijack sessions.
///
/// On logout: revokedAt = now(). On token rotation: old row revoked,
/// new row inserted.
model RefreshToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  deviceInfo String?   @map("device_info") // user-agent or app version
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================
// CATALOG — Phase 2 (lookups referenced by branches & visits)
// ============================================

/// Geographic region. Cities and branches reference it.
model Region {
  id     String  @id @default(cuid())
  nameAr String  @map("name_ar")
  nameEn String? @map("name_en")

  cities   City[]
  branches Branch[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("regions")
}

/// City within a region. Branches reference both region and city.
model City {
  id       String  @id @default(cuid())
  regionId String  @map("region_id")
  region   Region  @relation(fields: [regionId], references: [id])
  nameAr   String  @map("name_ar")
  nameEn   String? @map("name_en")

  branches Branch[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([regionId])
  @@index([deletedAt])
  @@map("cities")
}

/// Admin-managed list of reasons a supervisor can pick when marking a
/// visit as "Not Implemented". Visit instances FK into this table.
model NotImplementedReason {
  id      String  @id @default(cuid())
  titleAr String  @map("title_ar")
  titleEn String? @map("title_en")

  visitInstances  VisitInstance[]
  additionalTasks AdditionalTask[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("not_implemented_reasons")
}

// ============================================
// REGION SCHEDULING — FRD §4.2.2.2.1
// ============================================
// RegionScheduling is a STANDALONE entity. Its company/city/region/
// category fields are denormalised STRINGS — they do NOT FK into the
// Companies/Cities/Regions/Categories catalog tables. The admin enters
// them directly (typically via Excel import). This is intentional per
// FRD §4.2.2.2.1; do not "improve" by switching to FKs.
// ============================================

/// One row per (branch + visit blueprint) the admin wants supervisors
/// to visit. The actual visit instances (V1..V4) are generated later
/// when an admin assigns a supervisor and a start date.
model RegionScheduling {
  id             String   @id @default(cuid())
  companyName    String   @map("company_name")
  branchName     String   @map("branch_name")
  categoryName   String?  @map("category_name")
  branchNumber   String?  @map("branch_number")
  city           String
  region         String
  address        String?
  /// Free-text location field. The admin pastes a Google Maps link
  /// or "lat,lng" string here; the service parses out latitude /
  /// longitude on save and keeps the original text for display.
  location       String?
  latitude       Decimal?
  longitude      Decimal?
  /// 1..4 — drives how many V's are generated and the visit-type list.
  numberOfVisits Int      @default(1) @map("number_of_visits")
  code           String?

  requiredTasks         RegionSchedulingTask[]
  scheduledVisits       ScheduledVisit[]
  accountantAssignments AccountantManagerRegionScheduling[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([companyName])
  @@index([city])
  @@index([region])
  @@index([code])
  @@index([deletedAt])
  @@map("region_schedulings")
}

/// Tasks the supervisor must complete during a specific visit type
/// (V1/V2/V3/V4) of a region scheduling record. Bilingual.
model RegionSchedulingTask {
  id                 String           @id @default(cuid())
  regionSchedulingId String           @map("region_scheduling_id")
  regionScheduling   RegionScheduling @relation(fields: [regionSchedulingId], references: [id], onDelete: Cascade)
  /// 1=V1, 2=V2, 3=V3, 4=V4
  visitType          Int              @map("visit_type")
  titleAr            String           @map("title_ar")
  titleEn            String?          @map("title_en")
  sortOrder          Int              @default(0) @map("sort_order")

  /// Per-visit instances of this task that the supervisor checks off.
  visitChecks VisitInstanceTaskCheck[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([regionSchedulingId, visitType])
  @@map("region_scheduling_tasks")
}

/// M:N between an Accountant Manager (User with role=ACCOUNTANT_MANAGER)
/// and the region schedulings they're explicitly granted access to.
/// Only consulted when the user's `assignedToAllBranches` is false.
model AccountantManagerRegionScheduling {
  userId             String @map("user_id")
  regionSchedulingId String @map("region_scheduling_id")

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  regionScheduling RegionScheduling @relation(fields: [regionSchedulingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@id([userId, regionSchedulingId])
  @@index([regionSchedulingId])
  @@map("accountant_manager_region_schedulings")
}

// ============================================
// MANAGER TASKS — FRD §4.2.1.3
// ============================================

/// Admin-assigned to-dos for a specific manager. The manager toggles
/// `done` to indicate completion. Pure todo list — no scheduling.
model ManagerTask {
  id          String  @id @default(cuid())
  managerId   String  @map("manager_id")
  manager     User    @relation("AssignedToManager", fields: [managerId], references: [id], onDelete: Cascade)
  title       String
  description String?
  done        Boolean @default(false)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([managerId])
  @@index([done])
  @@index([deletedAt])
  @@map("manager_tasks")
}

// ============================================
// CONTACT-US MESSAGES — FRD §2.4 + §4.12 + FR-63 → FR-68
// ============================================

/// A message sent from a COMPANY_USER or ACCOUNTANT_MANAGER to admins
/// through the in-app Contact form. The admin sees the list in §4.12
/// and may reply; the user then pulls /company/contact/my-messages and
/// reads the reply (or receives a notification when we wire that up).
///
/// We store `email` and `phone` separately from the User.email/phone
/// because FR-65 explicitly asks the sender to fill them in on the
/// form, which suggests they may differ from the login identity
/// (e.g. a company assistant filing a ticket on someone's behalf).
model ContactMessage {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation("ContactMessageSender", fields: [userId], references: [id], onDelete: Cascade)

  email   String
  phone   String
  message String

  status ContactMessageStatus @default(PENDING)

  // Admin reply — populated only after an admin acts. Null until then.
  reply            String?
  repliedAt        DateTime? @map("replied_at")
  repliedByAdminId String?   @map("replied_by_admin_id")
  repliedBy        User?     @relation("ContactMessageAdmin", fields: [repliedByAdminId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("contact_messages")
}

// ============================================
// ADDITIONAL TASKS — FRD §1.4 + §3.9
// ============================================

/// Manager-assigned ad-hoc visits, outside the regular monthly schedule.
/// Unlike a ScheduledVisit which derives its location from RegionScheduling,
/// an AdditionalTask carries its own company / branch / address fields
/// because it can target any place — even one not in the catalog.
///
/// Phase C.1 covers the manager-side CRUD only. The supervisor's visit
/// lifecycle (start / complete / photos / OTP) lands in Phase C.2 and
/// will fill in startedAt / endedAt / documentation fields.
model AdditionalTask {
  id String @id @default(cuid())

  managerId    String @map("manager_id")
  manager      User   @relation("AdditionalTaskAssignedBy", fields: [managerId], references: [id])
  supervisorId String @map("supervisor_id")
  supervisor   User   @relation("AdditionalTaskAssignedTo", fields: [supervisorId], references: [id])

  // Free-text destination — FRD §3.9.2 lists Company / Brand / Address
  // as separate fields, not foreign keys. The manager types them in.
  companyName  String   @map("company_name")
  branchName   String?  @map("branch_name")
  categoryName String?  @map("category_name")
  address      String
  /// Google Maps URL or lat,lng text — same convention as RegionScheduling.
  location     String?
  latitude     Decimal?
  longitude    Decimal?

  visitDate DateTime @map("visit_date")
  price     Decimal?
  notes     String?

  // Visit state — set by the supervisor. Defaults to REMAINING so a
  // freshly-created task is immediately discoverable in the pending list.
  status              VisitStatus         @default(REMAINING)
  documentationStatus DocumentationStatus @default(UNDOCUMENTED)

  // Visit-execution state — persisted when the supervisor acts on the task
  // (Figma "Start visit" → GPS + timer; "Complete" → duration). Mirrors the
  // VisitInstance execution columns so the mobile flow is identical.
  startedAt       DateTime? @map("started_at")
  endedAt         DateTime? @map("ended_at")
  durationSeconds Int?      @map("duration_seconds")
  startLatitude   Decimal?  @map("start_latitude")
  startLongitude  Decimal?  @map("start_longitude")
  lockedAt        DateTime? @map("locked_at")

  notImplementedReasonId String?               @map("not_implemented_reason_id")
  notImplementedReason   NotImplementedReason? @relation(fields: [notImplementedReasonId], references: [id])
  notImplementedNote     String?               @map("not_implemented_note")
  visitNote              String?               @map("visit_note")

  // ── Visit documentation (FRD §1.4.4.1 / §3.9.6) ─────────────────────
  // Mirrors the VisitInstance documentation columns: once IMPLEMENTED the
  // supervisor sends a 4-digit OTP + a public link to the branch manager's
  // phone; the manager fills job number / rating / comments via the link;
  // the supervisor verifies the OTP to flip documentationStatus.
  branchManagerPhone   String?   @map("branch_manager_phone")
  documentationOtpHash String?   @map("documentation_otp_hash")
  otpExpiresAt         DateTime? @map("otp_expires_at")
  documentationToken   String?   @unique @map("documentation_token")
  jobNumber            String?   @map("job_number")
  rating               Int? // 1..5, validated at service layer
  comments             String?
  documentedAt         DateTime? @map("documented_at")

  photos     AdditionalTaskPhoto[]
  taskChecks AdditionalTaskCheck[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([managerId])
  @@index([supervisorId])
  @@index([visitDate])
  @@index([status])
  @@index([deletedAt])
  @@map("additional_tasks")
}

/// Manager-defined required tasks for an additional task (FRD §1.4.4.1).
/// Unlike VisitInstanceTaskCheck (snapshotted from a branch's
/// RegionSchedulingTask), these are authored directly by the manager when
/// creating the task — an additional task has no predefined task list. The
/// supervisor toggles `done` while executing the visit.
model AdditionalTaskCheck {
  id               String         @id @default(cuid())
  additionalTaskId String         @map("additional_task_id")
  additionalTask   AdditionalTask @relation(fields: [additionalTaskId], references: [id], onDelete: Cascade)

  titleAr   String  @map("title_ar")
  titleEn   String? @map("title_en")
  sortOrder Int     @default(0) @map("sort_order")
  done      Boolean @default(false)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([additionalTaskId])
  @@map("additional_task_checks")
}

/// Photos the supervisor captures while executing an additional task
/// (FRD §1.4.4.1 "upload or capture 3 to 4 photos"). Mirrors
/// VisitInstancePhoto but on the AdditionalTask table.
model AdditionalTaskPhoto {
  id               String         @id @default(cuid())
  additionalTaskId String         @map("additional_task_id")
  additionalTask   AdditionalTask @relation(fields: [additionalTaskId], references: [id], onDelete: Cascade)
  url              String
  sizeBytes        Int?           @map("size_bytes")
  mimeType         String?        @map("mime_type")
  uploadedAt       DateTime       @default(now()) @map("uploaded_at")
  deletedAt        DateTime?      @map("deleted_at")

  @@index([additionalTaskId])
  @@map("additional_task_photos")
}

// ============================================
// MONTHLY SALES / CLIENTS — FRD §3.7 + §4.9
// ============================================

/// Sales contract / client record managed by managers.
///
/// FRD §3.7.2 references three admin-managed lookups:
///   • Contract Type
///   • Tax (Tax Type)
///   • Contract Status
/// These are now admin-managed dropdowns backed by the Lookup table
/// (FRD §4.9.2). The Client stores FKs into Lookup; the service
/// layer asserts each FK references a row of the correct type so we
/// can't accidentally save `contractTypeId = <a Lookup of type AREA>`.
model Client {
  id String @id @default(cuid())

  /// The manager who created the client record. We keep it so future
  /// reports can attribute sales to specific managers per FRD §4.9.1.
  managerId String @map("manager_id")
  manager   User   @relation("ClientCreatedBy", fields: [managerId], references: [id])

  name      String
  statement String?
  website   String?
  price     Decimal?
  date      DateTime
  notes     String?

  /// Admin-managed lookup FKs. All three are nullable to match the
  /// FRD §3.7.2 wording ("select from admin-managed list") — the
  /// manager picks one when known, leaves blank otherwise.
  contractTypeId   String? @map("contract_type_id")
  contractType     Lookup? @relation("ClientContractType", fields: [contractTypeId], references: [id])
  taxTypeId        String? @map("tax_type_id")
  taxType          Lookup? @relation("ClientTaxType", fields: [taxTypeId], references: [id])
  contractStatusId String? @map("contract_status_id")
  contractStatus   Lookup? @relation("ClientContractStatus", fields: [contractStatusId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([managerId])
  @@index([name])
  @@index([date])
  @@index([contractStatusId])
  @@index([deletedAt])
  @@map("clients")
}

// ============================================
// LOOKUPS — FRD §4.9.2 + §4.10.2
// ============================================
// One row per admin-managed dropdown option. The `type` discriminator
// tells you which dropdown the row belongs to. Replaces what used to
// be six free-text columns scattered across Client + CarCase.
//
// Why one shared table instead of six separate ones: the CRUD shape
// is identical across all six (bilingual title + sort hint), and
// keeping them together lets the admin module ship one set of
// endpoints instead of six near-duplicates. The trade-off is that
// type integrity (Client.contractTypeId → Lookup{type: CONTRACT_TYPE})
// has to be enforced in the service layer, since SQL FKs can't
// constrain to a subset of rows.
// ============================================

model Lookup {
  id      String     @id @default(cuid())
  type    LookupType
  titleAr String     @map("title_ar")
  titleEn String?    @map("title_en")

  /// Sort hint for the FE dropdown. Defaults to 0 — admins can
  /// reorder by setting this in the PATCH body.
  sortOrder Int @default(0) @map("sort_order")

  /// TAX_TYPE only: the tax percentage (e.g. 15.00 for "VAT 15%"), so the
  /// monthly-sales dropdown can render "VAT 15%" and reports can compute
  /// tax. NULL for every other lookup type. Decimal(5,2) covers 0.00–999.99.
  percentage Decimal? @db.Decimal(5, 2)

  /// Back-refs so Prisma surfaces the relations cleanly. We don't
  /// actually use them on read paths today; they exist for future
  /// "where is this lookup used?" admin tooling.
  clientsAsContractType      Client[]  @relation("ClientContractType")
  clientsAsTaxType           Client[]  @relation("ClientTaxType")
  clientsAsContractStatus    Client[]  @relation("ClientContractStatus")
  carCasesAsArea             CarCase[] @relation("CarCaseArea")
  carCasesAsLicensePlate     CarCase[] @relation("CarCaseLicensePlate")
  carCasesAsVehicleCondition CarCase[] @relation("CarCaseVehicleCondition")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  /// Hot path: list dropdown options for a given type, sorted.
  @@index([type, deletedAt, sortOrder])
  @@map("lookups")
}

// ============================================
// CAR CASES — FRD §3.8 + §4.10
// ============================================

/// Vehicle assignment + condition tracking for supervisors. Each case
/// links a supervisor to a vehicle (license plate) within an area.
///
/// Area / License Plate / Vehicle Condition are now FKs into the
/// shared Lookup table (FRD §4.10.2). The service layer enforces
/// that each FK targets the correct LookupType.
model CarCase {
  id String @id @default(cuid())

  /// Manager who created the record.
  managerId String @map("manager_id")
  manager   User   @relation("CarCaseCreatedBy", fields: [managerId], references: [id])

  /// Supervisor the vehicle is assigned to (FRD §3.8.2 "Supervisor Name (selectable)").
  supervisorId String @map("supervisor_id")
  supervisor   User   @relation("CarCaseSupervisor", fields: [supervisorId], references: [id])

  /// Admin-managed lookup FKs. NOT NULL — every car case must point
  /// at an area, a vehicle, and a condition row to be meaningful.
  areaId             String @map("area_id")
  area               Lookup @relation("CarCaseArea", fields: [areaId], references: [id])
  licensePlateId     String @map("license_plate_id")
  licensePlate       Lookup @relation("CarCaseLicensePlate", fields: [licensePlateId], references: [id])
  vehicleConditionId String @map("vehicle_condition_id")
  vehicleCondition   Lookup @relation("CarCaseVehicleCondition", fields: [vehicleConditionId], references: [id])

  oilChangeDate DateTime? @map("oil_change_date")
  notes         String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([managerId])
  @@index([supervisorId])
  @@index([areaId])
  @@index([licensePlateId])
  @@index([deletedAt])
  @@map("car_cases")
}

// ============================================
// REPRESENTATIVES — FRD §3.10 + §4.11
// ============================================

/// Admin-managed catalog of service types offered to clients (FRD §4.11.2).
/// Each row owns the canonical `hourlyRate` used to price Representative
/// agreements. The manager picks a ServiceType by id when creating an
/// agreement; the rate is looked up server-side so managers can't
/// fabricate prices.
model ServiceType {
  id         String  @id @default(cuid())
  nameAr     String  @map("name_ar")
  nameEn     String? @map("name_en")
  hourlyRate Decimal @map("hourly_rate")

  representatives Representative[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("service_types")
}

/// Service agreement with a client. The price is computed by the
/// server from `hourlyRate × numberOfWorkers × numberOfHours` and
/// persisted alongside the inputs so the row is traceable even if
/// the underlying ServiceType.hourlyRate later changes.
model Representative {
  id String @id @default(cuid())

  /// Manager who created the agreement.
  managerId String @map("manager_id")
  manager   User   @relation("RepresentativeCreatedBy", fields: [managerId], references: [id])

  clientName String @map("client_name")

  /// FK to the admin-managed ServiceType. The hourlyRate is read from
  /// here at create/update time and snapshotted into `price`.
  serviceTypeId String      @map("service_type_id")
  serviceType   ServiceType @relation(fields: [serviceTypeId], references: [id])

  numberOfWorkers Int     @map("number_of_workers")
  numberOfHours   Decimal @map("number_of_hours")

  /// Computed: ServiceType.hourlyRate * numberOfWorkers * numberOfHours
  /// at the time of create/update. Stored (not a view) so historical
  /// reports don't drift if the ServiceType.hourlyRate is edited later.
  price Decimal

  dateOfAgreement     DateTime @map("date_of_agreement")
  customerPhoneNumber String?  @map("customer_phone_number")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([managerId])
  @@index([serviceTypeId])
  @@index([clientName])
  @@index([dateOfAgreement])
  @@index([deletedAt])
  @@map("representatives")
}

// ============================================
// COMPANIES & BRANCHES — Phase 3
// ============================================

/// Client organisation that owns one or more branches we visit.
/// Has a single login account (User with role=COMPANY_USER) created
/// atomically with the Company.
model Company {
  id     String  @id @default(cuid())
  nameAr String  @map("name_ar")
  nameEn String? @map("name_en")

  /// Optional contact info for the company entity itself
  /// (different from the login user's email/phone).
  contactEmail String? @map("contact_email")
  contactPhone String? @map("contact_phone")

  loginUsers User[]
  branches   Branch[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("companies")
}

/// Branch category (e.g. "Hypermarket", "Express", "Pharmacy").
/// Optional on branches per FRD §1.2.4.
model Category {
  id     String  @id @default(cuid())
  nameAr String  @map("name_ar")
  nameEn String? @map("name_en")

  branches Branch[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("categories")
}

/// A physical branch belonging to a Company. The unit a supervisor visits.
model Branch {
  id String @id @default(cuid())

  companyId  String    @map("company_id")
  company    Company   @relation(fields: [companyId], references: [id])
  categoryId String?   @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id])
  regionId   String    @map("region_id")
  region     Region    @relation(fields: [regionId], references: [id])
  cityId     String    @map("city_id")
  city       City      @relation(fields: [cityId], references: [id])

  nameAr       String   @map("name_ar")
  nameEn       String?  @map("name_en")
  branchNumber String?  @map("branch_number")
  code         String?
  addressAr    String?  @map("address_ar")
  addressEn    String?  @map("address_en")
  latitude     Decimal?
  longitude    Decimal?

  /// 1..4 — drives schedule generation in Phase 4.
  visitsPerMonth Int @default(1) @map("visits_per_month")

  requiredTasks BranchRequiredTask[]
  // Note: ScheduledVisit no longer links to Branch — see RegionScheduling
  // (FRD §4.2.2.2.1). Branch is kept as a catalog record for reference
  // and may be removed later if it stays unused.

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([companyId])
  @@index([regionId])
  @@index([cityId])
  @@index([code])
  @@index([deletedAt])
  @@map("branches")
}

/// Tasks the supervisor must complete during a visit of a given visit type
/// at a specific branch. (V1 of branch X has a different list than V2.)
model BranchRequiredTask {
  id        String  @id @default(cuid())
  branchId  String  @map("branch_id")
  branch    Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  visitType Int     @map("visit_type") // 1=V1, 2=V2, 3=V3, 4=V4
  titleAr   String  @map("title_ar")
  titleEn   String? @map("title_en")
  sortOrder Int     @default(0) @map("sort_order")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([branchId, visitType])
  @@map("branch_required_tasks")
}

// Add the inverse of Region/City relations to branches (Prisma needs this)
// Region.branches and City.branches are added below via separate model edits.

// ============================================
// SCHEDULING & VISIT EXECUTION — Phase 4
// ============================================

/// One per (supervisor, year, month). Holds the supervisor's full
/// schedule of branch visits for that month. Drafts have publishedAt
/// = NULL; once the admin "publishes", supervisors can see the schedule.
model MonthlySchedule {
  id           String    @id @default(cuid())
  supervisorId String    @map("supervisor_id")
  supervisor   User      @relation(fields: [supervisorId], references: [id])
  year         Int
  month        Int // 1..12
  publishedAt  DateTime? @map("published_at")

  scheduledVisits ScheduledVisit[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([supervisorId, year, month])
  @@index([deletedAt])
  @@map("monthly_schedules")
}

/// Admin's input level. One row per (branch, schedule) for REGULAR
/// type, or per ad-hoc assignment for ADDITIONAL type.
/// The system generates one VisitInstance per V1/V2/V3/V4 from this row.
model ScheduledVisit {
  id   String             @id @default(cuid())
  type ScheduledVisitType

  /// REGULAR: required link to the schedule. ADDITIONAL: NULL.
  monthlyScheduleId String?          @map("monthly_schedule_id")
  monthlySchedule   MonthlySchedule? @relation(fields: [monthlyScheduleId], references: [id], onDelete: Cascade)

  /// ADDITIONAL only: who assigned and to whom.
  assignedByManagerId    String? @map("assigned_by_manager_id")
  assignedByManager      User?   @relation("AssignedByManager", fields: [assignedByManagerId], references: [id])
  assignedToSupervisorId String? @map("assigned_to_supervisor_id")
  assignedToSupervisor   User?   @relation("AssignedToSupervisor", fields: [assignedToSupervisorId], references: [id])

  /// FRD §4.2.2.2.1 §3 "Assign Supervisors": admin assigns a supervisor
  /// to one or more region scheduling records. ScheduledVisit links to
  /// the region scheduling, NOT the legacy Branches table.
  regionSchedulingId String           @map("region_scheduling_id")
  regionScheduling   RegionScheduling @relation(fields: [regionSchedulingId], references: [id])
  numberOfVisits     Int              @default(1) @map("number_of_visits")
  firstVisitDate     DateTime         @map("first_visit_date") @db.Date

  /// ADDITIONAL only: extra metadata.
  price Decimal?
  notes String?

  visitInstances VisitInstance[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([monthlyScheduleId])
  @@index([regionSchedulingId])
  @@index([type])
  @@index([assignedToSupervisorId])
  @@index([deletedAt])
  @@map("scheduled_visits")
}

/// One per V1, V2, V3, V4 — the actual unit a supervisor visits.
/// Status transitions are enforced in the service layer; once a
/// terminal status is reached, locked_at is set and updates are refused.
model VisitInstance {
  id               String         @id @default(cuid())
  scheduledVisitId String         @map("scheduled_visit_id")
  scheduledVisit   ScheduledVisit @relation(fields: [scheduledVisitId], references: [id], onDelete: Cascade)
  visitOrder       Int            @map("visit_order") // 1=V1, 2=V2, 3=V3, 4=V4
  scheduledDate    DateTime       @map("scheduled_date") @db.Date

  status              VisitStatus         @default(REMAINING)
  documentationStatus DocumentationStatus @default(UNDOCUMENTED) @map("documentation_status")

  notImplementedReasonId String?               @map("not_implemented_reason_id")
  notImplementedReason   NotImplementedReason? @relation(fields: [notImplementedReasonId], references: [id])

  /// Free-text note the supervisor adds alongside a Not-Implemented reason,
  /// shown when the chosen reason is "Other" (Figma: Additional Notes).
  notImplementedNote String? @map("not_implemented_note")

  /// Optional free-text note the supervisor adds when completing a visit
  /// (Figma: Visit Details → "Notes (optional)").
  visitNote String? @map("visit_note")

  /// Recorded automatically when the supervisor starts/finishes the visit.
  startedAt       DateTime? @map("started_at")
  endedAt         DateTime? @map("ended_at")
  durationSeconds Int?      @map("duration_seconds")

  /// GPS captured at start.
  startLatitude  Decimal? @map("start_latitude")
  startLongitude Decimal? @map("start_longitude")

  /// For OTP-based documentation flow.
  branchManagerPhone String? @map("branch_manager_phone")

  /// OTP sent to the branch manager so they can document the visit
  /// via a public link (FRD §1.2.3.1 §2.5). Stored as a hash, not
  /// plaintext.
  documentationOtpHash String?   @map("documentation_otp_hash")
  otpExpiresAt         DateTime? @map("otp_expires_at")

  /// Public token used in the URL we send to the branch manager. Long,
  /// random, single-use. Cleared once submission lands.
  documentationToken String? @unique @map("documentation_token")

  /// Branch-manager-provided documentation fields.
  jobNumber    String?   @map("job_number")
  rating       Int? // 1..5, validated at service layer
  comments     String?
  documentedAt DateTime? @map("documented_at")

  /// Set when status reaches a terminal state. The service layer
  /// refuses any update if locked_at IS NOT NULL.
  lockedAt DateTime? @map("locked_at")

  /// If this instance was auto-created because an earlier V was marked
  /// FINAL_CLOSED, point to the source instance.
  cascadedFromVisitInstanceId String?         @map("cascaded_from_visit_instance_id")
  cascadedFromVisitInstance   VisitInstance?  @relation("VisitCascade", fields: [cascadedFromVisitInstanceId], references: [id])
  cascadedTo                  VisitInstance[] @relation("VisitCascade")

  photos     VisitInstancePhoto[]
  taskChecks VisitInstanceTaskCheck[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([scheduledVisitId, visitOrder])
  @@index([scheduledDate])
  @@index([status])
  @@index([lockedAt])
  @@index([deletedAt])
  @@map("visit_instances")
}

/// Photos uploaded during a visit (FRD §1.2.3.1 §2.3).
/// Optional 3–4 per visit; service layer enforces the cap.
model VisitInstancePhoto {
  id              String        @id @default(cuid())
  visitInstanceId String        @map("visit_instance_id")
  visitInstance   VisitInstance @relation(fields: [visitInstanceId], references: [id], onDelete: Cascade)
  url             String
  sizeBytes       Int?          @map("size_bytes")
  mimeType        String?       @map("mime_type")
  uploadedAt      DateTime      @default(now()) @map("uploaded_at")
  deletedAt       DateTime?     @map("deleted_at")

  @@index([visitInstanceId])
  @@map("visit_instance_photos")
}

/// Per-visit checklist of the required tasks. We snapshot the task
/// titles (titleAr/titleEn) at creation time so renames on
/// RegionSchedulingTask don't rewrite history.
model VisitInstanceTaskCheck {
  id              String        @id @default(cuid())
  visitInstanceId String        @map("visit_instance_id")
  visitInstance   VisitInstance @relation(fields: [visitInstanceId], references: [id], onDelete: Cascade)

  /// Source task (kept for traceability; nullable so deleting a task
  /// definition doesn't orphan past records).
  regionSchedulingTaskId String?               @map("region_scheduling_task_id")
  regionSchedulingTask   RegionSchedulingTask? @relation(fields: [regionSchedulingTaskId], references: [id])

  titleAr String  @map("title_ar")
  titleEn String? @map("title_en")
  done    Boolean @default(false)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([visitInstanceId])
  @@map("visit_instance_task_checks")
}

// ============================================
// SYSTEM
// ============================================

/// Simple key/value store for platform-wide settings.
/// Example keys: "maintenance_mode", "default_sms_sender".
model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ============================================
// MARKETPLACE — Phase 4 / Sprint 3
// ============================================
// Satellite tables for marketplace-specific data. The User row holds
// auth (email/password/status); these tables hold business-domain
// fields. 1:1 with User via `userId`. onDelete: Cascade — deleting
// the auth account removes the marketplace profile too.
// ============================================

/// A Customer is a marketplace buyer. Account self-created via
/// /auth/customer/signup with email-OTP verification (FRD §1.1).
model Customer {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  profilePicture String? @map("profile_picture")

  /// In-app wallet balance, used Sprint 4 (FRD §1.1 Wallet Balance Setup).
  /// Decimal(12,2) gives 10 integer digits + 2 fractional — enough for SAR.
  walletBalance Decimal @default(0) @map("wallet_balance") @db.Decimal(12, 2)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("customers")
}

/// A ServiceProvider is a marketplace seller. Account self-created via
/// /auth/service-provider/signup with email-OTP verification (FRD §2.1).
/// Bookings, service offerings, and ratings are wired Sprint 4.
model ServiceProvider {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  profilePicture String? @map("profile_picture")
  bio            String?

  /// "Service Type" the SP registered for (FRD §2.1 Sign-Up — selectable,
  /// admin-managed). Reuses the marketplace ServiceCategory catalog: pending
  /// requests are routed to the SP when booking.service.categoryId matches.
  /// Nullable so existing rows and in-progress signups stay valid.
  serviceCategoryId String?          @map("service_category_id")
  serviceCategory   ServiceCategory? @relation(fields: [serviceCategoryId], references: [id])

  // ── KYC / verification (Sprint 4 admin review flow) ────────────────
  /// Convenience flag derived from kycStatus = APPROVED. Kept as its
  /// own column so list queries don't have to compare enums.
  isVerified Boolean   @default(false) @map("is_verified")
  kycStatus  KycStatus @default(NOT_SUBMITTED) @map("kyc_status")
  verifiedAt DateTime? @map("verified_at")

  // ── Financials (Sprint 4) ──────────────────────────────────────────
  walletBalance Decimal @default(0) @map("wallet_balance") @db.Decimal(12, 2)

  // ── Ratings (Sprint 4, denormalised for fast list display) ─────────
  /// Average over all reviews. NULL until first review.
  ratingAverage Decimal? @map("rating_average") @db.Decimal(3, 2)
  ratingCount   Int      @default(0) @map("rating_count")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([kycStatus])
  @@index([isVerified])
  @@index([serviceCategoryId])
  @@index([deletedAt])
  @@map("service_providers")
}

/// Short-lived verification code (e.g. signup OTP, password-reset OTP).
/// Verifies an *identifier* (email/phone), not a user — so it works
/// before the User row exists. Deliberately not related to User.
///
/// Why a hash, not the code: if the DB is ever leaked, codes stay private.
/// Why `consumedAt` instead of deleting: audit trail (did the user verify?).
/// Why `attempts`: cheap brute-force defence — invalidate after N tries.
model OneTimeCode {
  id         String             @id @default(cuid())
  identifier String // email or phone the OTP was delivered to
  codeHash   String             @map("code_hash") // bcrypt hash, never plaintext
  purpose    OneTimeCodePurpose
  expiresAt  DateTime           @map("expires_at")
  consumedAt DateTime?          @map("consumed_at") // single-use; null until verified
  attempts   Int                @default(0)
  createdAt  DateTime           @default(now()) @map("created_at")

  @@index([identifier, purpose])
  @@index([expiresAt])
  @@map("one_time_codes")
}

// ============================================
// MARKETPLACE CATALOG — Sprint 3
// ============================================
// FRD §3.4 (admin) and §1.2 (customer home).
//
// Three-level hierarchy:
//   ServiceCategory  →  Service  →  ServiceSubcategory
//
// Cost lives ONLY on Subcategory. The "Service Cost" the customer
// sees on a service tile is the sum of selected subcategories
// (§1.2.1 + §1.2.2). The server computes it; it is never stored on
// Service itself — keeping a single source of truth.
//
// Naming: prefixed "Service*" to avoid collision with the existing
// `Category` model used by branches in the Management System.
// ============================================

/// Top-level grouping shown on the customer home (§1.2.3 "View Categories").
/// Manages by admin (the FRD does not name a separate "Categories
/// Management" section, but §1.2.3 lists Name + Icon as customer-visible,
/// so the admin must be able to create/edit them — we infer §3.4 covers it).
model ServiceCategory {
  id        String  @id @default(cuid())
  titleAr   String  @map("title_ar")
  titleEn   String? @map("title_en")
  iconUrl   String? @map("icon_url")
  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  services Service[]

  /// SPs who registered this category as their "Service Type" (FRD §2.1).
  serviceProviders ServiceProvider[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([isActive, deletedAt])
  @@index([sortOrder])
  @@map("service_categories")
}

/// A marketplace service (e.g. "Plumbing") — admin-managed via §3.4.1.
/// Belongs to one ServiceCategory. Its price is *not* stored here; it
/// is computed at request time as the sum of its (selected) subcategories.
model Service {
  id         String          @id @default(cuid())
  categoryId String          @map("category_id")
  category   ServiceCategory @relation(fields: [categoryId], references: [id])

  titleAr       String  @map("title_ar")
  titleEn       String? @map("title_en")
  descriptionAr String? @map("description_ar")
  descriptionEn String? @map("description_en")
  imageUrl      String? @map("image_url")

  /// Per-service commission rate in percent (FRD §3.4.1.5). Admin sets
  /// this; payouts deduct it at booking-settlement time (Sprint 4).
  commissionRate Decimal @default(0) @map("commission_rate") @db.Decimal(5, 2)

  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  subcategories ServiceSubcategory[]
  bookings      Booking[]
  reviews       Review[]

  // Denormalised aggregates from customer reviews (Sprint 4 review flow).
  // Kept on the row so list queries don't have to join + aggregate.
  ratingAverage Decimal? @map("rating_average") @db.Decimal(3, 2)
  ratingCount   Int      @default(0) @map("rating_count")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([categoryId, isActive, deletedAt])
  @@index([sortOrder])
  @@index([ratingAverage])
  @@map("services")
}

/// A line item within a Service. The CUSTOMER picks one or more of these;
/// the total cost displayed is the sum of the picked ones (§1.2.2 +
/// §1.2.4 "Cost Range" filter). Cascade-deleted with the parent Service.
model ServiceSubcategory {
  id        String  @id @default(cuid())
  serviceId String  @map("service_id")
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  titleAr String  @map("title_ar")
  titleEn String? @map("title_en")
  cost    Decimal @db.Decimal(12, 2)

  sortOrder Int @default(0) @map("sort_order")

  bookingSubcategories BookingSubcategory[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([serviceId, deletedAt])
  @@map("service_subcategories")
}

// ============================================
// MARKETPLACE BOOKINGS — Sprint 4 (early start)
// ============================================
// FRD §1.3 (customer booking), §2.2 + §2.3 (SP pool + lifecycle),
// §3.3 (admin oversight).
//
// State machine:
//
//   PENDING ──(SP accepts)──→ APPROVED ──(SP starts)──→ IN_PROGRESS
//      │                                                   │
//      │                                                   ▼
//      ▼                                                COMPLETED
//   CANCELLED        REJECTED  (expired/admin-rejected;
//   (customer)        Sprint 4+)
//
// Subcategories snapshot:
//   Each `BookingSubcategory` row copies titleAr/titleEn/cost from
//   ServiceSubcategory at booking time. So if admin later raises a
//   subcategory's price, that change applies to NEW bookings only —
//   historical totals stay frozen.
//
// Commission lock:
//   On APPROVED the row captures the Service.commissionRate at that
//   moment + computes commissionAmount = totalCost * rate / 100.
//   Admin changing the rate afterwards does NOT retroactively change
//   what the SP owes.
// ============================================

/// A marketplace booking from a Customer for a specific Service.
/// The selected subcategories determine the totalCost (snapshot in
/// BookingSubcategory). Lifecycle is tracked via `status`.
model Booking {
  id String @id @default(cuid())

  // Who, what, when
  customerId String @map("customer_id")
  customer   User   @relation("BookingCustomer", fields: [customerId], references: [id])

  serviceId String  @map("service_id")
  service   Service @relation(fields: [serviceId], references: [id])

  /// NULL until an SP accepts (transitions PENDING → APPROVED).
  /// Once set, it's the locked assignment — no reassignment without
  /// a cancel + new booking.
  assignedSpId String? @map("assigned_sp_id")
  assignedSp   User?   @relation("BookingSp", fields: [assignedSpId], references: [id])

  selectedSubcategories BookingSubcategory[]

  // Request details (captured at creation)
  description     String?  @db.Text
  locationLat     Decimal? @map("location_lat") @db.Decimal(10, 7)
  locationLng     Decimal? @map("location_lng") @db.Decimal(10, 7)
  locationAddress String?  @map("location_address")
  scheduledDate   DateTime @map("scheduled_date")

  /// Relative public paths (/uploads/bookings/...) of photos the customer
  /// attached to the request (Marketplace §1.3). Uploaded first via
  /// POST /customer/uploads, then their urls are sent here on create.
  /// Stored relative so any API host can serve them. Empty when none.
  photoUrls String[] @map("photo_urls")

  // Pricing — locked at creation
  totalCost Decimal @map("total_cost") @db.Decimal(12, 2)

  // Commission — locked at APPROVED (NULL while PENDING / CANCELLED)
  commissionRate   Decimal? @map("commission_rate") @db.Decimal(5, 2)
  commissionAmount Decimal? @map("commission_amount") @db.Decimal(12, 2)

  // Status + payment
  status        BookingStatus        @default(PENDING)
  paymentMethod BookingPaymentMethod
  paymentStatus BookingPaymentStatus @default(PENDING)

  // Lifecycle timestamps
  approvedAt         DateTime? @map("approved_at")
  startedAt          DateTime? @map("started_at")
  completedAt        DateTime? @map("completed_at")
  /// When the SP confirmed "Amount Received" for a CASH booking (FRD
  /// §2.3.1.1). NULL for non-cash or until the SP confirms. Completion no
  /// longer auto-marks CASH as paid — this explicit step does.
  cashReceivedAt     DateTime? @map("cash_received_at")
  cancelledAt        DateTime? @map("cancelled_at")
  cancellationReason String?   @map("cancellation_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// At most one review per booking (enforced by Review.bookingId unique).
  /// Populated once the customer rates the COMPLETED booking.
  review Review?

  /// Wallet ledger entries that reference this booking — every
  /// BOOKING_DEBIT / REFUND / BOOKING_CREDIT / COMMISSION_DEBIT tied
  /// to this booking ends up here. Useful for "show me every cent
  /// that moved because of booking X" in admin tools.
  walletTransactions WalletTransaction[]

  /// Disputes filed about this booking. A booking can have multiple
  /// disputes over its lifetime (customer + SP each raise one, or the
  /// same user files twice for different issues).
  disputes Dispute[]

  /// Per-SP "Reject" records. The booking stays in the open pool for
  /// everyone else; it just disappears from each dismissing SP's list.
  dismissals BookingDismissal[]

  @@index([customerId, status])
  @@index([assignedSpId, status])
  @@index([status, createdAt]) // pool query: PENDING ordered by oldest first
  @@index([serviceId])
  @@map("bookings")
}

/// Snapshot of a subcategory picked at booking time. Cost/title are
/// frozen here so later admin edits to ServiceSubcategory don't bleed
/// retroactively into historical bookings (or their commission math).
model BookingSubcategory {
  id        String  @id @default(cuid())
  bookingId String  @map("booking_id")
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  subcategoryId String             @map("subcategory_id")
  subcategory   ServiceSubcategory @relation(fields: [subcategoryId], references: [id])

  // Frozen at booking time
  titleAr String  @map("title_ar")
  titleEn String? @map("title_en")
  cost    Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([bookingId, subcategoryId])
  @@index([bookingId])
  @@map("booking_subcategories")
}

/// One row per (SP, booking) the SP "rejected" on their pending screen
/// (FRD §2.2.2 "Reject Request → removed from Pending Requests"). In the
/// open-pool model this is a per-SP dismissal, NOT a global rejection:
/// the booking stays PENDING and visible to every other matching SP.
model BookingDismissal {
  id        String  @id @default(cuid())
  bookingId String  @map("booking_id")
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  spId      String  @map("sp_id")
  sp        User    @relation("BookingDismissalSp", fields: [spId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([bookingId, spId])
  @@index([spId])
  @@map("booking_dismissals")
}

// ============================================
// MARKETPLACE REVIEWS — Sprint 4
// ============================================
// FRD §1.2.1 / §1.2.2 (rating shown to customer) + §2 (SP receives
// review on their work). A review is created by the customer who
// placed the booking, after it transitions to COMPLETED.
//
// Aggregation strategy:
//   The Service and ServiceProvider tables carry denormalised
//   ratingAverage + ratingCount columns. On every review create we
//   recompute both aggregates inside the same transaction so list
//   endpoints (Customer Home, admin SP list) never have to join +
//   AVG() at read time. ratingAverage is Decimal(3,2) → range 0.00
//   to 5.00 with 2 decimal places.
//
// Immutability:
//   Reviews are frozen on submit (no PATCH / DELETE in MVP). If we
//   later need edit-window support, add an `editedAt` column and
//   allow updates within N minutes — schema is forward-compatible.
//
// One review per booking:
//   Enforced by @unique on bookingId. The customer can review their
//   COMPLETED bookings exactly once. If they want to revise, that's
//   an admin workflow (Sprint 4+).
// ============================================

model Review {
  id String @id @default(cuid())

  /// At most one review per booking — the unique constraint guarantees
  /// the customer can't double-review the same job.
  bookingId String  @unique @map("booking_id")
  booking   Booking @relation(fields: [bookingId], references: [id])

  /// Who left the review. Denormalised from booking.customerId, kept
  /// here so SP-side queries don't need a 2-hop join.
  customerId String @map("customer_id")
  customer   User   @relation("ReviewCustomer", fields: [customerId], references: [id])

  /// Who received it. Denormalised from booking.assignedSpId.
  serviceProviderId String @map("service_provider_id")
  serviceProvider   User   @relation("ReviewServiceProvider", fields: [serviceProviderId], references: [id])

  /// Which service the review is for. Lets Customer Home aggregate
  /// rating per service (without joining through bookings).
  serviceId String  @map("service_id")
  service   Service @relation(fields: [serviceId], references: [id])

  /// 1..5 stars (FRD §1.2.1 "Service Rating").
  rating Int

  /// Optional free-text comment. Capped at 1000 chars at the validation
  /// layer; @db.Text in case we relax that later.
  comment String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([serviceProviderId])
  @@index([serviceId])
  @@index([customerId])
  @@map("reviews")
}

// ============================================
// NOTIFICATIONS — Sprint 4
// ============================================
// FRD §1.4, §2.4, §1.5, §2.5, §3.13, §4.14 — cross-cutting in-app
// notifications. Stored in DB, fetched by the client via
// /notifications. No push / email channels in MVP — added later via
// strategy pattern around the notify() helper.
//
// Why type is an enum + free-form data JSON:
//   - The enum gives DB-level validation + autocomplete on the client.
//   - The JSON blob carries module-specific payload (bookingId,
//     reviewId, amount) for deep-linking, without needing a new
//     column per notification type.
//
// Read state:
//   - readAt is NULL until the user opens it. Filtering ?unread=true
//     becomes WHERE read_at IS NULL — fast with the (userId, readAt)
//     composite index.
//
// Bilingual content:
//   - title/body each have ar + en. The producer (the wiring side)
//     writes both; the client picks based on user locale.
// ============================================

model Notification {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type NotificationType

  titleAr String  @map("title_ar")
  titleEn String? @map("title_en")
  bodyAr  String? @map("body_ar")
  bodyEn  String? @map("body_en")

  /// Module-specific deep-link payload. e.g. { bookingId, serviceId }
  /// for BOOKING_*; { kycStatus, notes } for KYC_*. Client treats as
  /// opaque other than known keys per type.
  data Json?

  /// NULL until the recipient marks it read.
  readAt DateTime? @map("read_at")

  /// Set when this notification was fanned out from an admin broadcast
  /// (FRD §4.14 / §3.6 marketplace). NULL for event-driven notifications
  /// (booking, kyc, etc.). SetNull on broadcast delete so the user's
  /// inbox row survives even if the admin removes the broadcast.
  broadcastId String?                @map("broadcast_id")
  broadcast   NotificationBroadcast? @relation(fields: [broadcastId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  /// Hot path: list mine ordered by newest, optionally filtered to
  /// unread. The (userId, readAt) order matches both queries.
  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([broadcastId])
  @@map("notifications")
}

/// One row per admin "send broadcast" event. Represents the admin's
/// intent — title, body, audience — separate from the per-user
/// Notification rows that get fanned out at send time.
///
/// Why a separate model rather than grouping notifications by
/// (createdAt, title): the admin needs to view / delete the broadcast
/// as a single unit (FRD §3.6 marketplace, §4.14 mgmt). Grouping by
/// fuzzy fields breaks when notifications get edited / partially
/// deleted / land at different timestamps in a busy send.
model NotificationBroadcast {
  id            String @id @default(cuid())
  sentByAdminId String @map("sent_by_admin_id")
  sentByAdmin   User   @relation("BroadcastSentByAdmin", fields: [sentByAdminId], references: [id])

  titleAr String  @map("title_ar")
  titleEn String? @map("title_en")
  bodyAr  String  @map("body_ar")
  bodyEn  String? @map("body_en")

  /// Frozen snapshot of the audience the admin selected at send time.
  /// Shape: { kind: 'ALL' } | { kind: 'ROLES', roles: SystemRole[] } |
  /// { kind: 'USERS', userIds: string[] }.
  /// Stored even though we also write Notification rows so audit /
  /// "view who got it" survives later user deletions.
  audience Json

  /// Count of Notification rows we successfully wrote at send time.
  /// Lets the admin see "delivered to N users" without a JOIN.
  recipientCount Int @map("recipient_count")

  notifications Notification[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([sentByAdminId])
  @@index([deletedAt])
  @@map("notification_broadcasts")
}

// ============================================
// E-WALLET LEDGER — Sprint 4
// ============================================
// FRD §1.1 "Wallet Balance Setup" + §2.1 + §3.5 (admin financial).
//
// Each user's wallet is a denormalised balance column on the satellite
// (Customer.walletBalance, ServiceProvider.walletBalance). Every
// movement also writes a WalletTransaction row — the LEDGER — for
// audit + history.
//
// Invariants:
//   1. balanceAfter on every row = sum of all signed amounts up to and
//      including that row. If they drift, there's a bug — the ledger
//      lets us bisect when it happened.
//   2. All amounts in `amount` are POSITIVE. The sign is implied by
//      `type` (see WalletTransactionType comment). The wallet service
//      helper enforces this when computing the new balance.
//   3. Balance cannot go negative for CUSTOMER (insufficient funds →
//      400). For SP, commission debit can push balance negative; admin
//      can later add a TOPUP / ADJUSTMENT_CREDIT to reconcile.
// ============================================

model WalletTransaction {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type WalletTransactionType

  /// Always positive in DB; direction applied by service layer based on `type`.
  amount Decimal @db.Decimal(12, 2)

  /// Snapshot of the user's wallet balance AFTER this txn was applied.
  /// Audit trail — lets us spot drift from the denormalised
  /// Customer/ServiceProvider.walletBalance columns.
  balanceAfter Decimal @map("balance_after") @db.Decimal(12, 2)

  /// Optional source reference for booking-related transactions
  /// (BOOKING_DEBIT, BOOKING_CREDIT, COMMISSION_DEBIT, REFUND).
  bookingId String?  @map("booking_id")
  booking   Booking? @relation(fields: [bookingId], references: [id])

  /// External payment-provider reference (PayTabs txn id) — populated
  /// when wallet top-up came from a real payment gateway. Sprint 4+.
  externalRef String? @map("external_ref")

  /// Free-text human note. Admin-typed for ADJUSTMENT / manual top-up;
  /// auto-generated for booking events ("Payment for booking abc123").
  note String?

  /// Back-reference for WITHDRAWAL transactions. NULL for every other
  /// type. The withdrawal row owns the FK (walletTransactionId) so it
  /// can be set atomically with the wallet debit.
  withdrawalRequest WithdrawalRequest?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([bookingId])
  @@map("wallet_transactions")
}

/// Tracks a customer wallet top-up through the PayTabs hosted-payment flow.
/// One row per "Add balance" attempt. The wallet is credited (via a TOPUP
/// WalletTransaction) only when PayTabs confirms success on the callback —
/// guarded by `status` so a duplicated callback can never double-credit.
model WalletTopup {
  id         String      @id @default(cuid())
  customerId String      @map("customer_id")
  amount     Decimal     @db.Decimal(12, 2)
  currency   String      @default("SAR")
  status     TopupStatus @default(PENDING)

  /// cart_id sent to PayTabs (also the idempotency key on the callback).
  cartId String @unique @map("cart_id")
  /// PayTabs tran_ref — filled after the payment session is created.
  tranRef    String? @unique @map("tran_ref")
  paymentUrl String? @map("payment_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([customerId])
  @@index([status])
  @@map("wallet_topups")
}

enum TopupStatus {
  PENDING
  COMPLETED
  FAILED
}

// ============================================
// WITHDRAWAL REQUESTS — Sprint 4 (FRD §3.5.2)
// ============================================
// SP-side cash-out flow. SPs build up balance through completed
// WALLET bookings (BOOKING_CREDIT - COMMISSION_DEBIT). Withdrawals
// pull money OUT of the wallet via the same WalletTransaction
// ledger, just typed as WITHDRAWAL.
//
// Lifecycle: SP submits PENDING → admin reviews → APPROVED (with
// bank ref) or REJECTED (with note) or CANCELLED (by SP before
// admin reviewed).
//
// Money invariant:
//   - On PENDING create: NO wallet movement yet. The admin is the
//     one who actually wires the bank transfer, so the wallet debit
//     happens at the APPROVED moment, atomically with status update.
//   - This means an SP CAN have PENDING > balance if their balance
//     drops after submitting (e.g. an ADJUSTMENT_DEBIT). To prevent
//     that, we enforce a single-PENDING-at-a-time rule per SP.
//
// Bank details:
//   - Captured per-request for MVP. When SP profile gains a "saved
//     bank account" entity later, the request body becomes optional
//     and falls back to the saved details.
// ============================================

model WithdrawalRequest {
  id String @id @default(cuid())

  /// The SP requesting the withdrawal.
  spId String @map("sp_id")
  sp   User   @relation("WithdrawalSp", fields: [spId], references: [id])

  /// Always positive. Validated against SP balance at create time;
  /// debited from the wallet at admin-approval time.
  amount Decimal @db.Decimal(12, 2)

  /// Withdrawal channel for THIS request. Defaults to BANK so existing
  /// rows (all bank transfers) stay correct after the migration.
  method WithdrawalMethod @default(BANK)

  // SP-provided BANK details (present when method = BANK). Nullable now
  // that EWALLET is a valid method; the validation layer requires them
  // only for BANK requests.
  bankName          String? @map("bank_name")
  bankAccountIban   String? @map("bank_account_iban")
  accountHolderName String? @map("account_holder_name")

  // SP-provided E-WALLET details (present when method = EWALLET).
  walletName String? @map("wallet_name")
  walletId   String? @map("wallet_id")

  status WithdrawalStatus @default(PENDING)

  /// Admin who reviewed it (NULL while PENDING / CANCELLED-by-SP).
  reviewedById String?   @map("reviewed_by_id")
  reviewedBy   User?     @relation("WithdrawalAdmin", fields: [reviewedById], references: [id])
  reviewedAt   DateTime? @map("reviewed_at")

  /// On APPROVED: admin pastes the bank's transfer reference here
  /// (mandatory at the validation layer — proof the money actually
  /// moved). On REJECTED: NULL.
  bankTransferRef String? @map("bank_transfer_ref")

  /// On REJECTED: admin's reason (visible to SP). On APPROVED: optional
  /// notes ("Wire fees absorbed by platform" etc.).
  adminNote String? @map("admin_note")

  /// Optional reason captured when the SP cancels their own request.
  cancellationReason String? @map("cancellation_reason")

  /// FK to the WalletTransaction created when this withdrawal was
  /// approved. Lets us trace request → ledger row → balance change
  /// without ambiguity.
  walletTransactionId String?            @unique @map("wallet_transaction_id")
  walletTransaction   WalletTransaction? @relation(fields: [walletTransactionId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([spId, status])
  @@index([status, createdAt]) // pending queue for admin
  @@map("withdrawal_requests")
}

// ============================================
// DISPUTES — FRD §3.6 (marketplace)
// ============================================
// User files a complaint → admin reviews and responds. Both Customer
// and Service Provider can file. The dispute can optionally reference
// a Booking (e.g., "the SP never showed up for booking #123"); when
// it doesn't, it's a generic platform complaint (e.g., "the app keeps
// crashing").
// ============================================

/// A complaint filed by a marketplace user (Customer or SP). Admins
/// triage these from PENDING → IN_REVIEW → RESOLVED, optionally
/// writing back a response that gets surfaced to the filer.
model Dispute {
  id String @id @default(cuid())

  /// Who filed it. Always a CUSTOMER or SERVICE_PROVIDER user.
  /// We do NOT denormalise the role onto the dispute row — read
  /// `user.role` if you need it, it can't change for a given user
  /// without going through admin tools.
  userId String @map("user_id")
  user   User   @relation("DisputeFiledBy", fields: [userId], references: [id])

  /// Free-text subject + body. The validation layer enforces length
  /// limits; we accept plain text only (the FE strips formatting).
  subject String
  message String

  /// Optional context — links a dispute to a specific booking the
  /// user is complaining about. Null when the dispute is generic
  /// (e.g., app bug, billing question).
  bookingId String?  @map("booking_id")
  booking   Booking? @relation(fields: [bookingId], references: [id])

  status DisputeStatus @default(PENDING)

  /// Admin response + audit trail. All three move together: when the
  /// admin patches in a response, `respondedAt` is stamped and
  /// `respondedByAdminId` is set. They stay NULL until then.
  adminResponse      String?
  respondedByAdminId String?   @map("responded_by_admin_id")
  respondedByAdmin   User?     @relation("DisputeRespondedBy", fields: [respondedByAdminId], references: [id])
  respondedAt        DateTime? @map("responded_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([userId])
  @@index([status, createdAt]) // admin queue: oldest pending first
  @@index([bookingId])
  @@index([deletedAt])
  @@map("disputes")
}

# ============================================
# Bareeq Backend — Environment Variables Template
# Copy this file to `.env` and fill in real values
# NEVER commit the real .env file to git
# ============================================

# --- Application ---
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
# Public base URL of THIS backend (no trailing slash). Used to build absolute
# links to public assets/documents (e.g. visit-documentation PDFs). In
# production set this to the real https URL, otherwise links default to
# http://localhost:3000 and break for external clients.
PUBLIC_BASE_URL=http://localhost:3000

# --- Database (PostgreSQL) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/bareeq_dev

# --- Redis (for OTP, cache, queues) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT Auth ---
JWT_ACCESS_SECRET=change_me_to_a_long_random_string_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_to_a_different_long_random_string
JWT_REFRESH_EXPIRES_IN=7d

# --- SMS (Taqnyat / Msegat) ---
SMS_PROVIDER=taqnyat
SMS_API_KEY=
SMS_SENDER_NAME=Bareeq

# --- Email ---
EMAIL_FROM=noreply@bareeq.sa
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- Firebase Cloud Messaging ---
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# --- Cloudinary (file storage) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- PayTabs (payment gateway) ---
PAYTABS_PROFILE_ID=
PAYTABS_SERVER_KEY=
PAYTABS_REGION=SAU
# API base for PayTabs requests (Saudi region default).
PAYTABS_BASE_URL=https://secure.paytabs.sa
# Public origin of THIS API (no trailing slash) — used to build the PayTabs
# callback/return URLs. MUST be the real deployed host in production, e.g.
# https://82-25-118-152.sslip.io  (PayTabs must be able to reach it).
# TEMPORARY: credit the wallet directly on /customer/wallet/topup WITHOUT
# PayTabs (for testing before a real merchant account exists). Set to false
# and configure PAYTABS_* once the real account is ready. Free top-ups while on!
WALLET_TOPUP_TEST_MODE=false

# --- OTP Settings ---
OTP_LENGTH=4
OTP_EXPIRY_MINUTES=5

# TEMPORARY testing toggle — turn OFF before real launch.
# When true, OTP flows behave like dev even in production: a failed email
# is non-fatal AND the OTP is returned in the API response so a tester can
# complete signup/reset without a working mailbox (Customer + SP apps).
OTP_TEST_MODE=false
# Master code that always passes OTP verification while OTP_TEST_MODE=true
# (SP flow). 4 digits to match the SP OTP format.
OTP_TEST_CODE=0000

# --- Logging ---
LOG_LEVEL=debug

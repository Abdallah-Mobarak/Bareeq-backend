# =============================================================
# .gitattributes — Git's per-file behavior config
# =============================================================
# Forces LF line endings for all text files regardless of OS.
# Eliminates the "LF will be replaced by CRLF" warnings and
# prevents fake merge conflicts caused by Windows vs Mac/Linux
# line-ending differences.
# =============================================================

# Default: auto-detect text vs binary, normalize text to LF
* text=auto eol=lf

# Source code (explicit just to be safe)
*.js       text eol=lf
*.cjs      text eol=lf
*.mjs      text eol=lf
*.ts       text eol=lf

# Config & data
*.json     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.toml     text eol=lf
*.env      text eol=lf
*.example  text eol=lf

# Docs
*.md       text eol=lf

# Database
*.prisma   text eol=lf
*.sql      text eol=lf

# Shell scripts MUST be LF (Windows CRLF breaks them on Linux)
*.sh       text eol=lf

# Binary files — never touch
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.svg      text eol=lf
*.pdf      binary
*.zip      binary
*.tar.gz   binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.eot      binary
